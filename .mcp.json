{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "chrome-devtools": {
      "command": "cmd.exe",
      "args": [
        "/c",
        "npx",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "-y"
      ]
    },
    "flowform-dev": {
      "command": "/usr/bin/bash",
      "args": ["${CLAUDE_PROJECT_DIR:-.}/tools/mcp/run.sh"]
    }
  }
}
