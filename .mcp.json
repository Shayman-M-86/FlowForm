{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "chrome-devtools": {
      "command": "cmd.exe",
      "args": [
        "/c",
        "npx",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "-y"
      ]
    }
  }
}
