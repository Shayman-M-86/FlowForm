{
    "version": "2.0.0",
    "tasks": [
        {
    "label": "Setup backend",
    "type": "shell",
    "runOptions": {
        "runOn": "folderOpen"
    },
    "group": {
        "kind": "build",
        "isDefault": true
    },
    "windows": {
        "command": "powershell",
        "args": [
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            "${workspaceFolder}/backend/scripts/bootstrap/bootstrap.ps1"
        ]
    },
    "linux": {
        "command": "bash",
        "args": [
            "${workspaceFolder}/backend/scripts/bootstrap/bootstrap.sh"
        ]
    },
    "osx": {
        "command": "bash",
        "args": [
            "${workspaceFolder}/backend/scripts/bootstrap/bootstrap.sh"
        ]
    },
    "options": {
        "cwd": "${workspaceFolder}/backend"
    },
    "problemMatcher": []
    } ] }