{
    "include": [
        "app",
        "tests"
    ],
    "exclude": [
        "**/__pycache__",
        ".venv",
        ".pytest_cache",
        ".ruff_cache", 
        "**/node_modules", 
        "**/.*"
    ],
    "typeCheckingMode": "standard",
    "venvPath": ".",
    "venv": ".venv",
    "pythonVersion": "3.14",
    "reportMissingImports": true,
    "reportMissingTypeStubs": false
}