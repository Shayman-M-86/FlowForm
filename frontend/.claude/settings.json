{
  "permissions": {
    "allow": [
      "Bash(npm run dev:studio:*)",
      "Bash(npm run dev:site:*)",
      "Bash(npm run build:studio:*)",
      "Bash(npm run build:site:*)",

      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run preview:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run routes:*)",

      "Bash(npx tsc --noEmit:*)",
      "Bash(npx tsc -b:*)",

      "Bash(npx tsr generate:*)",

      "Bash(npx astro check:*)",
      "Bash(npx astro info:*)",

      "Bash(npx eslint:*)"
    ],
    "deny": [
      "Bash(npm install:*)",
      "Bash(npm install --save:*)",
      "Bash(npm install --save-dev:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm ci:*)",
      "Bash(npx --yes:*)",

      "Bash(npx eslint --fix:*)",

      "Bash(npm publish:*)",
      "Bash(npm pack:*)",
      "Bash(npm link:*)",

      "Bash(rm -rf node_modules:*)",
      "Bash(rm -rf */node_modules:*)"
    ]
  }
}
