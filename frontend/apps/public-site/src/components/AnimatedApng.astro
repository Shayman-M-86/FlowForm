---
interface Props {
  src: string;
  alt?: string;
  width?: number | string;
  height?: number | string;
  class?: string;
  style?: string;
}

const { src, alt = '', width = 200, height = 200, class: className, style } = Astro.props;
---

<span
  class:list={['apng-wrap', className]}
  data-src={src}
  data-alt={alt}
  style={`width:${typeof width === 'number' ? `${width}px` : width}; height:${typeof height === 'number' ? `${height}px` : height}; ${style ?? ''}`}
>
  <canvas
    class="apng-canvas"
    width={typeof width === 'number' ? width : undefined}
    height={typeof height === 'number' ? height : undefined}
    aria-label={alt}
    role="img"
  ></canvas>
</span>

<script>
  type ApngCacheWindow = Window & {
    __flowformApngBlobCache?: Map<string, Promise<string>>;
  };

  const cacheWindow = window as ApngCacheWindow;
  const apngBlobCache =
    cacheWindow.__flowformApngBlobCache ?? new Map<string, Promise<string>>();
  cacheWindow.__flowformApngBlobCache = apngBlobCache;

  const getApngBlobUrl = (src: string) => {
    const cached = apngBlobCache.get(src);
    if (cached) return cached;

    const blobUrlPromise = fetch(src)
      .then((response) => {
        if (!response.ok) throw new Error(`Failed to load APNG: ${src}`);
        return response.blob();
      })
      .then((blob) => URL.createObjectURL(blob));

    apngBlobCache.set(src, blobUrlPromise);
    return blobUrlPromise;
  };

  document.querySelectorAll<HTMLElement>('.apng-wrap').forEach((wrap) => {
    if (wrap.dataset.apngInitialized === 'true') return;
    wrap.dataset.apngInitialized = 'true';

    const AUTO_PLAY_MIN_DURATION_MS = 1400;
    const AUTO_PLAY_MAX_DURATION_MS = 2600;
    const AUTO_PLAY_MIN_DELAY_MS = 800;
    const AUTO_PLAY_MAX_DELAY_MS = 11000;
    const AUTO_PLAY_CHECK_MS = 750;

    const canvas = wrap.querySelector<HTMLCanvasElement>('.apng-canvas')!;
    const ctx = canvas.getContext('2d')!;
    const src = wrap.dataset.src!;
    const animatedImage = new Image();
    let playableSrc: string | null = null;
    let isLoaded = false;
    let isHovering = false;
    let isAutoPlaying = false;
    let autoPlayInterval: number | null = null;
    let autoHideTimeout: number | null = null;
    let fadeTimeout: number | null = null;
    let nextAutoPlayAt = 0;

    animatedImage.className = 'apng-clone';
    animatedImage.alt = wrap.dataset.alt ?? '';
    wrap.appendChild(animatedImage);

    const syncCanvasSize = () => {
      const rect = wrap.getBoundingClientRect();
      const ratio = window.devicePixelRatio || 1;
      const width = Math.max(1, Math.round(rect.width * ratio));
      const height = Math.max(1, Math.round(rect.height * ratio));

      if (canvas.width !== width) canvas.width = width;
      if (canvas.height !== height) canvas.height = height;
    };

    const drawToCanvas = (image: CanvasImageSource) => {
      syncCanvasSize();
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.drawImage(image, 0, 0, canvas.width, canvas.height);
    };

    getApngBlobUrl(src)
      .then((blobUrl) => {
        playableSrc = blobUrl;

        const loader = new Image();
        loader.onload = () => {
          drawToCanvas(loader);
          isLoaded = true;
        };
        loader.src = blobUrl;

        animatedImage.src = blobUrl;
      })
      .catch(() => {
        playableSrc = src;

        const loader = new Image();
        loader.onload = () => {
          drawToCanvas(loader);
          isLoaded = true;
        };
        loader.src = src;

        animatedImage.src = src;
      });

    const getNextAutoPlayDelay = () => {
      return (
        AUTO_PLAY_MIN_DELAY_MS +
        Math.random() * (AUTO_PLAY_MAX_DELAY_MS - AUTO_PLAY_MIN_DELAY_MS)
      );
    };

    const getAutoPlayDuration = () => {
      return (
        AUTO_PLAY_MIN_DURATION_MS +
        Math.random() * (AUTO_PLAY_MAX_DURATION_MS - AUTO_PLAY_MIN_DURATION_MS)
      );
    };

    const scheduleNextAutoPlay = () => {
      nextAutoPlayAt = window.Date.now() + getNextAutoPlayDelay();
    };

    const clearAutoPlayInterval = () => {
      if (autoPlayInterval !== null) {
        window.clearInterval(autoPlayInterval);
        autoPlayInterval = null;
      }
    };

    const clearAutoHideTimeout = () => {
      if (autoHideTimeout !== null) {
        window.clearTimeout(autoHideTimeout);
        autoHideTimeout = null;
      }
    };

    const clearFadeTimeout = () => {
      if (fadeTimeout !== null) {
        window.clearTimeout(fadeTimeout);
        fadeTimeout = null;
      }
    };

    const scheduleCloneFadeOut = () => {
      clearFadeTimeout();
      fadeTimeout = window.setTimeout(() => {
        fadeTimeout = null;
        animatedImage.style.opacity = '0';
      }, 100);
    };

    const restartAnimation = () => {
      if (!playableSrc) return;

      animatedImage.src = '';
      requestAnimationFrame(() => {
        if (playableSrc) animatedImage.src = playableSrc;
      });
    };

    const showAnimation = () => {
      if (!isLoaded) return;

      clearFadeTimeout();
      clearAutoHideTimeout();
      restartAnimation();

      requestAnimationFrame(() => {
        canvas.style.opacity = '0';
        animatedImage.style.opacity = '1';
      });
    };

    const hideAnimation = () => {
      if (!isLoaded) return;

      drawToCanvas(animatedImage);
      canvas.style.opacity = '1';
      animatedImage.style.opacity = '1';
      scheduleCloneFadeOut();
    };

    const startAutoPlayLoop = () => {
      clearAutoPlayInterval();
      scheduleNextAutoPlay();

      autoPlayInterval = window.setInterval(() => {
        if (isHovering || isAutoPlaying || !isLoaded) return;
        if (window.Date.now() < nextAutoPlayAt) return;

        isAutoPlaying = true;
        showAnimation();
        const autoPlayDuration = getAutoPlayDuration();
        autoHideTimeout = window.setTimeout(() => {
          autoHideTimeout = null;
          isAutoPlaying = false;
          if (!isHovering) hideAnimation();
          scheduleNextAutoPlay();
        }, autoPlayDuration);
      }, AUTO_PLAY_CHECK_MS);
    };

    wrap.addEventListener('mouseenter', () => {
      isHovering = true;
      clearAutoHideTimeout();
      isAutoPlaying = false;
      showAnimation();
    });

    wrap.addEventListener('mouseleave', () => {
      isHovering = false;
      clearAutoHideTimeout();
      isAutoPlaying = false;
      hideAnimation();
      scheduleNextAutoPlay();
    });

    window.addEventListener('resize', () => {
      if (!isLoaded) return;
      drawToCanvas(animatedImage);
    });

    startAutoPlayLoop();
  });
</script>

<style>
  .apng-wrap {
    position: relative;
    display: inline-block;
    overflow: hidden;
    line-height: 0;
  }

  .apng-canvas,
  .apng-clone {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
    user-select: none;
    transition: opacity 0.1s linear;
  }

  .apng-canvas {
    z-index: 1;
    opacity: 1;
  }

  .apng-clone {
    z-index: 2;
    object-fit: contain;
    opacity: 0;
  }
</style>
