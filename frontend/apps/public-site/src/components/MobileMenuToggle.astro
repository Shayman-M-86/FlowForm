---
import Default from '@astrojs/starlight/components/MobileMenuToggle.astro';
---

<div class="flowform-mobile-menu-toggle">
  <Default><slot /></Default>
</div>

<script>
  const mountMobileMenuToggle = () => {
    const toggle = document.querySelector<HTMLElement>('.flowform-mobile-menu-toggle');
    const mobileTocSummary = document.getElementById('starlight__on-this-page--mobile');
    const sidebarPane = document.getElementById('starlight__sidebar');
    const sidebarCard = sidebarPane?.querySelector<HTMLElement>('.sidebar-content > .top-level');

    sidebarPane?.classList.add('flowform-mobile-sidebar-pane');
    sidebarCard?.classList.add('flowform-mobile-sidebar-card');

    if (!toggle || !mobileTocSummary || toggle.parentElement === mobileTocSummary) return;
    mobileTocSummary.appendChild(toggle);
  };

  document.addEventListener('astro:page-load', mountMobileMenuToggle);
  mountMobileMenuToggle();

  document.addEventListener(
    'click',
    (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (!target.closest('.flowform-mobile-menu-toggle')) return;

      event.preventDefault();
    },
    { capture: true },
  );
</script>

<style>
  .flowform-mobile-menu-toggle {
    display: inline-flex;
    flex-shrink: 0;
    margin-inline-start: auto;
    z-index: 80;
  }

  .flowform-mobile-menu-toggle :global(starlight-menu-button) {
    display: inline-flex;
  }

  .flowform-mobile-menu-toggle :global(button[aria-controls='starlight__sidebar']) {
    position: static !important;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--sl-color-hairline-shade);
    padding: 0.5rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    line-height: 1;
    box-shadow: none;
  }

  .flowform-mobile-menu-toggle :global([aria-expanded='true'] button[aria-controls='starlight__sidebar']),
  .flowform-mobile-menu-toggle :global(button[aria-controls='starlight__sidebar']:hover) {
    border-color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
    color: var(--sl-color-text-accent);
  }

  .flowform-mobile-menu-toggle :global(svg) {
    flex: 0 0 auto;
  }

  @media (min-width: 50rem) {
    .flowform-mobile-menu-toggle {
      display: none;
    }
  }
</style>

<style is:global>
  @media (max-width: 49.999rem) {
    .flowform-mobile-sidebar-pane {
      z-index: calc(var(--sl-z-index-toc) - 1) !important;
      inset-block: calc(var(--sl-nav-height) + var(--sl-mobile-toc-height)) 0 !important;
      background: var(--sl-color-bg-sidebar) !important;
    }

    .flowform-mobile-sidebar-pane .sidebar-content {
      padding: 1rem !important;
    }

    .flowform-mobile-sidebar-card {
      width: min(100%, 24rem) !important;
      margin: 0 auto !important;
      padding: 1rem !important;
      border: 1px solid var(--sl-color-hairline-shade) !important;
      border-radius: 14px !important;
      background: var(--sl-color-bg-sidebar) !important;
      box-shadow: var(--sl-shadow-lg) !important;
    }
  }
</style>
