---
import '@flowform/styles/tokens.css';
import '@flowform/site-shell/header.css';
import { ClientRouter } from 'astro:transitions';
const { head } = Astro.locals.starlightRoute;
const filteredHead = head.filter(({ tag, attrs }) => {
  if (tag !== 'link') return true;
  if (attrs?.href !== '/favicon.svg') return true;
  return attrs.rel !== 'icon' && attrs.rel !== 'shortcut icon';
});
---

<!-- Geist font — same as Layout.astro -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Geist+Mono:wght@100..900&display=optional"
  rel="stylesheet"
/>
<link rel="icon" type="image/webp" href="/FlowForm_logo.png" />

<ClientRouter />

{filteredHead.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
