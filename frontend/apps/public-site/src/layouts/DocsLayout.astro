---
import Layout from './Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import DocsNav from '../components/DocsNav.astro';

export interface Props {
  title: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
  currentPath: string;
}

const { title, description, headings = [], currentPath } = Astro.props;

interface DocsNavItem {
  label: string;
  href: string;
}

interface DocsNavGroup {
  label: string;
  items: DocsNavItem[];
}

const sidebar: DocsNavGroup[] = [
  {
    label: 'Getting Started',
    items: [
      { label: 'Introduction', href: '/docs/introduction' },
      { label: 'Building Your First Form', href: '/docs/building-your-first-form' },
    ],
  },
  {
    label: 'Question Types',
    items: [
      { label: 'Overview', href: '/docs/question-types/overview' },
    ],
  },
  {
    label: 'Reference',
    items: [
      { label: 'Survey JSON Shapes v1', href: '/docs/survey-json-shapes-v1' },
    ],
  },
];

const normalisePath = (path: string) => {
  if (path.length > 1 && path.endsWith('/')) return path.slice(0, -1);
  return path;
};

const current = normalisePath(currentPath);
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const activeItem = sidebar.flatMap(group => group.items).find(item => current === normalisePath(item.href));
const activeLabel = activeItem?.label ?? title;
---

<Layout title={`${title} | FlowForm Docs`} description={description} canonicalPath={currentPath}>
  <SiteHeader />

  <div class="docs-page">
    <div class="docs-mobile-bar" transition:animate="none">
      <button
        class="docs-mobile-bar__toggle"
        type="button"
        aria-expanded="false"
        aria-controls="docs-mobile-menu"
        aria-label="Open docs navigation"
        data-docs-toggle
      >
        <svg class="docs-mobile-bar__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 6h16M4 12h10M4 18h16" />
        </svg>

        <span class="docs-mobile-bar__label">{activeLabel}</span>

        <svg class="docs-mobile-bar__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 9l6 6 6-6" />
        </svg>
      </button>
    </div>

    <div class="docs-mobile-menu" id="docs-mobile-menu" hidden data-docs-menu>
      <DocsNav groups={sidebar} currentPath={currentPath} variant="mobile" />
    </div>

    <div class="docs-layout">
      <aside class="docs-sidebar" id="docs-sidebar">
        <DocsNav groups={sidebar} currentPath={currentPath} variant="sidebar" />
      </aside>

      <main class="docs-main" id="main-content">
        <article class="docs-article">
          <h1 class="docs-article__title">{title}</h1>
          {description && <p class="docs-article__description">{description}</p>}
          <div class="docs-content">
            <slot />
          </div>
        </article>

        <nav class="docs-pagination" aria-label="Page navigation">
          <slot name="pagination" />
        </nav>
      </main>

      {tocHeadings.length > 0 && (
        <aside class="docs-toc" aria-label="On this page">
          <p class="docs-toc__label">On this page</p>
          <ul class="docs-toc__list">
            {tocHeadings.map(heading => (
              <li class={`docs-toc__item docs-toc__item--h${heading.depth}`}>
                <a href={`#${heading.slug}`} class="docs-toc__link">{heading.text}</a>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </div>
  </div>
</Layout>

<script is:inline>
  (() => {
    const toggle = document.querySelector('[data-docs-toggle]');
    const menu = document.querySelector('[data-docs-menu]');
    if (!toggle || !menu) return;

    const setOpen = (open) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close docs navigation' : 'Open docs navigation');
      menu.hidden = !open;
    };

    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });

    menu.querySelectorAll('[data-docs-menu-link]').forEach(link => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', event => {
      if (event.key === 'Escape') setOpen(false);
    });

    document.addEventListener('click', event => {
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (!toggle.contains(target) && !menu.contains(target)) setOpen(false);
    });
  })();
</script>
