---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'FlowForm — Easy Form & Survey Builder',
  description = 'FlowForm is a secure, privacy-first form and survey builder. Build beautiful forms in minutes.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/webp" href="/FlowForm_logo.png" />

    <!-- theme-color: controls iOS status bar / Dynamic Island area color.
         Media-query tags cover the initial load; SiteHeader's applyTheme()
         updates theme-color-active after toggle using the live CSS variable. -->
    <meta name="theme-color" content="rgb(247 247 247)" media="(prefers-color-scheme: light)" id="theme-color-light" />
    <meta name="theme-color" content="rgb(30 30 32)" media="(prefers-color-scheme: dark)" id="theme-color-dark" />
    <meta name="theme-color" content="" id="theme-color-active" />

    <!-- Geist font from Vercel CDN -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Geist+Mono:wght@100..900&display=swap"
      rel="stylesheet"
    />

    <!-- Inline theme-init: apply .dark before first paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('flowform.theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var dark = stored === 'dark' || (!stored && prefersDark);
          if (dark) document.documentElement.classList.add('dark');
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
