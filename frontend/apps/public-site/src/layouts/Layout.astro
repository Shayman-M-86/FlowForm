---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const SITE_URL = 'https://flow-form.com.au';

const {
  title = 'FlowForm | Build Forms and Surveys',
  description = 'FlowForm is a form and survey builder for creating, sharing, and managing online forms. Five question types, visual logic, and privacy by design.',
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const canonicalURL = new URL(canonicalPath, SITE_URL).href;
const ogImage = `${SITE_URL}/FlowForm_logo.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/webp" href="/FlowForm_logo.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="FlowForm" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- theme-color: iOS reads these automatically based on OS mode.
         No JS override needed — media-query tags update instantly. -->
    <meta name="theme-color" content="rgb(247 247 247)" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="rgb(30 30 32)" media="(prefers-color-scheme: dark)" />

    <!-- Geist font from Vercel CDN -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Geist+Mono:wght@100..900&display=swap"
      rel="stylesheet"
    />

    <!-- Inline theme-init: apply .dark before first paint to avoid flash -->
    <script is:inline>
      (function () {
        var mq = window.matchMedia('(prefers-color-scheme: dark)');
        var resolveTheme = function () {
          try {
            var stored = localStorage.getItem('flowform.theme');
            if (stored === 'dark' || stored === 'light') return stored;
          } catch (_) {}
          // No explicit user preference — follow the OS
          return mq.matches ? 'dark' : 'light';
        };
        var apply = function (theme) {
          document.documentElement.classList.toggle('dark', theme === 'dark');
        };
        apply(resolveTheme());
        // Re-apply when OS light/dark mode changes, but only if user hasn't overridden
        mq.addEventListener('change', function () {
          try { if (localStorage.getItem('flowform.theme')) return; } catch (_) {}
          apply(mq.matches ? 'dark' : 'light');
        });
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
