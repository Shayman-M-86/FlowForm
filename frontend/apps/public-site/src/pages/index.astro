---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { NodePageIsland } from '../components/NodePageIsland';
---

<Layout title="FlowForm — Easy Form & Survey Builder">
  <SiteHeader />

  <main style="padding-top: 56px;">

    <!-- ─── Hero ──────────────────────────────────────────────── -->
    <section
      id="hero"
      style="
        text-align: center;
        padding: 80px 24px 60px;
        background: linear-gradient(
          160deg,
          var(--background) 0%,
          rgb(110 164 226 / 0.06) 50%,
          var(--background) 100%
        );
      "
    >
      <div style="max-width: 720px; margin: 0 auto;">
        <div
          style="
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 0.07em;
            text-transform: uppercase;
            color: var(--accent);
            background: rgb(110 164 226 / 0.1);
            border: 1px solid rgb(110 164 226 / 0.22);
            padding: 4px 12px;
            border-radius: 999px;
            margin-bottom: 24px;
          "
        >
          <span style="width:6px;height:6px;border-radius:999px;background:var(--accent);display:inline-block;"></span>
          Now in Beta · Free to use
        </div>

        <h1
          style="
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1.1;
            color: var(--foreground);
            margin: 0 0 20px;
          "
        >
          FlowForm<br />
          <span style="color: var(--primary);">An easy form builder</span>
        </h1>

        <p
          style="
            font-size: clamp(1rem, 2.2vw, 1.2rem);
            color: var(--muted-foreground);
            line-height: 1.65;
            margin: 0 auto 36px;
            max-width: 520px;
          "
        >
          Design powerful surveys and forms in minutes — no code, no complexity.
          Security-first architecture keeps your data where it belongs.
        </p>

        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          <a
            href="#builder"
            style="
              display: inline-flex;
              align-items: center;
              gap: 8px;
              font-size: 0.95rem;
              font-weight: 600;
              color: var(--primary-foreground);
              background: var(--primary);
              padding: 12px 28px;
              border-radius: var(--radius-xl);
              text-decoration: none;
              box-shadow: var(--app-shadow-md);
              transition: opacity 0.15s;
            "
          >
            Start building now →
          </a>
          <a
            href="#features"
            style="
              display: inline-flex;
              align-items: center;
              gap: 8px;
              font-size: 0.95rem;
              font-weight: 500;
              color: var(--foreground);
              background: var(--card);
              padding: 12px 28px;
              border-radius: var(--radius-xl);
              text-decoration: none;
              border: 1px solid var(--border);
              box-shadow: var(--app-shadow-sm);
              transition: background 0.15s;
            "
          >
            See features
          </a>
        </div>

        <!-- Social proof strip -->
        <div
          style="
            margin-top: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 32px;
            flex-wrap: wrap;
            font-size: 0.82rem;
            color: var(--muted-foreground);
            font-weight: 500;
          "
        >
          {[
            { icon: '🔒', text: 'End-to-end encrypted' },
            { icon: '⚡', text: 'Under 5 min to launch' },
            { icon: '🛡️', text: 'GDPR-ready' },
            { icon: '🎨', text: '5 question types' },
          ].map(({ icon, text }) => (
            <span style="display:flex;align-items:center;gap:6px;">
              <span>{icon}</span> {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── Builder ────────────────────────────────────────────── -->
    <section
      id="builder"
      style="
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        background: var(--background);
      "
    >
      <!-- Builder label bar -->
      <div
        style="
          max-width: 1080px;
          margin: 0 auto;
          padding: 28px 24px 0;
          display: flex;
          align-items: center;
          justify-content: space-between;
          flex-wrap: wrap;
          gap: 12px;
        "
      >
        <div>
          <p
            style="
              margin: 0;
              font-size: 0.75rem;
              font-weight: 700;
              letter-spacing: 0.08em;
              text-transform: uppercase;
              color: var(--accent);
              margin-bottom: 4px;
            "
          >
            Live builder
          </p>
          <h2
            style="
              margin: 0;
              font-size: clamp(1.3rem, 3vw, 1.8rem);
              font-weight: 700;
              letter-spacing: -0.02em;
              color: var(--foreground);
              border: none;
              padding: 0;
            "
          >
            Build your form, right here
          </h2>
        </div>
        <p style="margin:0;font-size:0.88rem;color:var(--muted-foreground);max-width:380px;line-height:1.5;">
          Everything auto-saves to your browser. No account needed to get started.
        </p>
      </div>

      <!-- NodePage island — full React app embedded -->
      <NodePageIsland client:only="react" />
    </section>


    <!-- ─── Features ───────────────────────────────────────────── -->
    <section
      id="features"
      style="
        padding: 100px 24px;
        background: var(--background);
      "
    >
      <div style="max-width: 1080px; margin: 0 auto;">
        <div style="text-align:center;margin-bottom:64px;">
          <p style="margin:0 0 10px;font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--accent);">
            Why FlowForm
          </p>
          <h2
            style="
              margin:0 0 16px;
              font-size:clamp(1.6rem,3.5vw,2.4rem);
              font-weight:800;
              letter-spacing:-0.025em;
              color:var(--foreground);
              border:none;padding:0;
            "
          >
            Everything you need,<br />nothing you don't
          </h2>
          <p style="margin:0 auto;max-width:480px;color:var(--muted-foreground);font-size:1rem;line-height:1.6;">
            FlowForm packs a professional-grade survey engine into a clean, intuitive interface.
          </p>
        </div>

        <div
          style="
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
          "
        >
          {[
            {
              icon: '🎯',
              title: 'Multiple question types',
              body: 'Multiple choice, matching, rating scales, open-ended fields, and conditional rules — everything a real survey demands.',
            },
            {
              icon: '⚙️',
              title: 'Visual logic builder',
              body: 'Set up skip logic and branching rules without writing a single line of code. Drag, drop, done.',
            },
            {
              icon: '🔍',
              title: 'Instant preview',
              body: 'Hit Preview and see exactly what respondents will experience before you share anything.',
            },
            {
              icon: '💾',
              title: 'Auto-save, always',
              body: 'Your work is saved to localStorage automatically. Refresh, close the tab — it\'ll be there when you return.',
            },
            {
              icon: '🎨',
              title: 'Consistent design',
              body: 'A polished, accessible UI with light and dark mode baked in. Looks great on every screen.',
            },
            {
              icon: '📤',
              title: 'Structured export',
              body: 'Serialize your entire survey to clean JSON, ready for your backend, API, or data pipeline.',
            },
          ].map(({ icon, title, body }) => (
            <div
              style="
                padding: 28px;
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 16px;
                box-shadow: var(--app-shadow-xs);
              "
            >
              <div
                style="
                  width: 44px;
                  height: 44px;
                  border-radius: 12px;
                  background: rgb(110 164 226 / 0.1);
                  display: flex;
                  align-items: center;
                  justify-content: center;
                  font-size: 1.3rem;
                  margin-bottom: 16px;
                "
              >
                {icon}
              </div>
              <h3 style="margin:0 0 10px;font-size:1rem;font-weight:700;color:var(--foreground);">{title}</h3>
              <p style="margin:0;font-size:0.88rem;color:var(--muted-foreground);line-height:1.6;">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── Security ───────────────────────────────────────────── -->
    <section
      id="security"
      style="
        padding: 100px 24px;
        background: linear-gradient(
          135deg,
          rgb(80 145 220 / 0.04) 0%,
          var(--background) 60%
        );
        border-top: 1px solid var(--border);
      "
    >
      <div style="max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;">
        <!-- Left copy -->
        <div>
          <p style="margin:0 0 10px;font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--accent);">
            Security first
          </p>
          <h2
            style="
              margin:0 0 20px;
              font-size:clamp(1.6rem,3vw,2.2rem);
              font-weight:800;
              letter-spacing:-0.025em;
              color:var(--foreground);
              border:none;padding:0;line-height:1.2;
            "
          >
            Your data is yours.<br />Full stop.
          </h2>
          <p style="margin:0 0 28px;color:var(--muted-foreground);font-size:1rem;line-height:1.7;">
            We built security into FlowForm from day one — not as an afterthought.
            Responses are stored in an isolated database with no cross-contamination,
            pseudonymous identity mapping keeps PII separate from answer data,
            and every submission flows through a hardened write saga with rollback protection.
          </p>

          <div style="display:flex;flex-direction:column;gap:14px;">
            {[
              { label: 'Pseudonymous responses', detail: 'Real user IDs never touch the response database — only stable anonymous UUIDs.' },
              { label: 'Dual-database isolation', detail: 'Survey structure and raw responses live in separate databases with no cross-DB foreign keys.' },
              { label: 'Atomic saga writes', detail: 'Submissions use a two-phase commit with automatic rollback. Partial writes are impossible.' },
              { label: 'GDPR-ready architecture', detail: 'Right-to-erasure is straightforward: pseudonymous mappings can be deleted independently.' },
            ].map(({ label, detail }) => (
              <div style="display:flex;gap:14px;align-items:flex-start;">
                <div
                  style="
                    flex-shrink:0;
                    width:22px;height:22px;
                    border-radius:999px;
                    background:rgb(22 163 74 / 0.12);
                    display:flex;align-items:center;justify-content:center;
                    margin-top:2px;
                  "
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="rgb(22 163 74)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </div>
                <div>
                  <p style="margin:0 0 2px;font-size:0.9rem;font-weight:600;color:var(--foreground);">{label}</p>
                  <p style="margin:0;font-size:0.83rem;color:var(--muted-foreground);line-height:1.55;">{detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: visual shield card -->
        <div
          style="
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 40px 36px;
            box-shadow: var(--app-shadow-lg);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 28px;
          "
        >
          <div
            style="
              width: 80px;height:80px;
              border-radius: 24px;
              background: linear-gradient(135deg, rgb(80 145 220 / 0.15), rgb(110 164 226 / 0.08));
              border: 1px solid rgb(110 164 226 / 0.2);
              display:flex;align-items:center;justify-content:center;
              font-size: 2.2rem;
            "
          >
            🛡️
          </div>

          <div style="width:100%;display:flex;flex-direction:column;gap:10px;">
            {[
              { label: 'Data encryption', status: 'Active', color: 'rgb(22 163 74)' },
              { label: 'Identity isolation', status: 'Active', color: 'rgb(22 163 74)' },
              { label: 'Audit logging', status: 'Active', color: 'rgb(22 163 74)' },
              { label: 'GDPR compliance', status: 'Ready', color: 'rgb(80 145 220)' },
              { label: 'SOC 2 (coming soon)', status: 'Planned', color: 'rgb(202 138 4)' },
            ].map(({ label, status, color }) => (
              <div
                style="
                  display:flex;align-items:center;justify-content:space-between;
                  padding:10px 14px;
                  background:var(--muted);
                  border-radius:10px;
                  font-size:0.85rem;
                "
              >
                <span style="font-weight:500;color:var(--foreground);">{label}</span>
                <span
                  style={`
                    font-weight:600;
                    color:${color};
                    font-size:0.78rem;
                    letter-spacing:0.04em;
                  `}
                >
                  ✓ {status}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── How it works ───────────────────────────────────────── -->
    <section
      style="
        padding: 100px 24px;
        border-top: 1px solid var(--border);
        background: var(--background);
      "
    >
      <div style="max-width: 860px; margin: 0 auto; text-align: center;">
        <p style="margin:0 0 10px;font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--accent);">
          How it works
        </p>
        <h2
          style="
            margin:0 0 56px;
            font-size:clamp(1.6rem,3.5vw,2.4rem);
            font-weight:800;
            letter-spacing:-0.025em;
            color:var(--foreground);
            border:none;padding:0;
          "
        >
          From zero to live form in three steps
        </h2>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:32px;text-align:left;">
          {[
            {
              step: '01',
              title: 'Add your questions',
              body: 'Choose from multiple choice, rating, field, matching, and rule nodes. Build your exact flow.',
            },
            {
              step: '02',
              title: 'Set logic & rules',
              body: 'Use the visual rules builder to add conditional branching, skip logic, and scoring rules.',
            },
            {
              step: '03',
              title: 'Preview & share',
              body: 'Hit Preview to test the respondent experience, then share the link or export the JSON schema.',
            },
          ].map(({ step, title, body }) => (
            <div style="position:relative;">
              <div
                style="
                  font-size:3rem;
                  font-weight:900;
                  letter-spacing:-0.04em;
                  color:rgb(110 164 226 / 0.15);
                  line-height:1;
                  margin-bottom:12px;
                "
              >
                {step}
              </div>
              <h3 style="margin:0 0 10px;font-size:1rem;font-weight:700;color:var(--foreground);">{title}</h3>
              <p style="margin:0;font-size:0.875rem;color:var(--muted-foreground);line-height:1.6;">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CTA band ───────────────────────────────────────────── -->
    <section
      id="pricing"
      style="
        padding: 80px 24px;
        border-top: 1px solid var(--border);
        background: linear-gradient(
          135deg,
          rgb(80 145 220 / 0.08) 0%,
          rgb(110 164 226 / 0.04) 100%
        );
        text-align: center;
      "
    >
      <div style="max-width:600px;margin:0 auto;">
        <h2
          style="
            margin:0 0 16px;
            font-size:clamp(1.6rem,4vw,2.4rem);
            font-weight:800;
            letter-spacing:-0.025em;
            color:var(--foreground);
            border:none;padding:0;
          "
        >
          Ready to build smarter forms?
        </h2>
        <p style="margin:0 0 36px;font-size:1.05rem;color:var(--muted-foreground);line-height:1.6;">
          FlowForm is free during beta. No credit card. No time limit.
          Just open the builder above and start creating.
        </p>
        <a
          href="#builder"
          style="
            display:inline-flex;
            align-items:center;
            gap:8px;
            font-size:1rem;
            font-weight:700;
            color:var(--primary-foreground);
            background:var(--primary);
            padding:14px 36px;
            border-radius:var(--radius-xl);
            text-decoration:none;
            box-shadow:var(--app-shadow-lg);
            transition:opacity 0.15s;
          "
        >
          Open the builder →
        </a>
        <p style="margin:20px 0 0;font-size:0.82rem;color:var(--muted-foreground);">
          No sign-up required · Auto-saves to your browser · Export anytime
        </p>
      </div>
    </section>


    <!-- ─── Footer ─────────────────────────────────────────────── -->
    <footer
      style="
        border-top: 1px solid var(--border);
        background: var(--card);
        padding: 64px 24px 40px;
      "
    >
      <div style="max-width:1080px;margin:0 auto;">
        <!-- Top row -->
        <div
          style="
            display:grid;
            grid-template-columns:2fr 1fr 1fr 1fr;
            gap:48px;
            margin-bottom:56px;
          "
        >
          <!-- Brand column -->
          <div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
              <div
                style="
                  width:30px;height:30px;border-radius:9px;
                  background:var(--primary);
                  display:flex;align-items:center;justify-content:center;
                "
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="3" />
                  <path d="M8 10h8M8 14h5" />
                </svg>
              </div>
              <span style="font-weight:800;font-size:1.05rem;letter-spacing:-0.02em;color:var(--foreground);">FlowForm</span>
            </div>
            <p style="margin:0 0 20px;font-size:0.875rem;color:var(--muted-foreground);line-height:1.7;max-width:280px;">
              A security-first form and survey builder. Fast to set up,
              powerful enough for real research, private by design.
            </p>
            <!-- Security badges -->
            <div style="display:flex;flex-wrap:wrap;gap:8px;">
              {['🔒 Encrypted', '🛡️ GDPR Ready', '🔑 Pseudonymous'].map((badge) => (
                <span
                  style="
                    font-size:0.72rem;
                    font-weight:600;
                    color:var(--muted-foreground);
                    background:var(--muted);
                    border:1px solid var(--border);
                    padding:3px 10px;
                    border-radius:999px;
                  "
                >
                  {badge}
                </span>
              ))}
            </div>
          </div>

          <!-- Product column -->
          <div>
            <p style="margin:0 0 16px;font-size:0.75rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:var(--foreground);">
              Product
            </p>
            <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:10px;">
              {['Form Builder', 'Question Types', 'Logic Rules', 'Export & API', 'Preview Mode'].map((item) => (
                <li>
                  <a
                    href="#builder"
                    style="font-size:0.875rem;color:var(--muted-foreground);text-decoration:none;transition:color 0.15s;"
                  >
                    {item}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Security column -->
          <div>
            <p style="margin:0 0 16px;font-size:0.75rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:var(--foreground);">
              Security
            </p>
            <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:10px;">
              {['Privacy Policy', 'Data Isolation', 'GDPR Compliance', 'Audit Logs', 'Pseudonymity'].map((item) => (
                <li>
                  <a
                    href="#security"
                    style="font-size:0.875rem;color:var(--muted-foreground);text-decoration:none;transition:color 0.15s;"
                  >
                    {item}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Company column -->
          <div>
            <p style="margin:0 0 16px;font-size:0.75rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:var(--foreground);">
              Company
            </p>
            <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:10px;">
              {['About', 'Blog', 'Changelog', 'Status', 'Contact'].map((item) => (
                <li>
                  <a
                    href="#"
                    style="font-size:0.875rem;color:var(--muted-foreground);text-decoration:none;transition:color 0.15s;"
                  >
                    {item}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Divider -->
        <div style="height:1px;background:var(--border);margin-bottom:28px;"></div>

        <!-- Bottom row -->
        <div
          style="
            display:flex;
            align-items:center;
            justify-content:space-between;
            flex-wrap:wrap;
            gap:16px;
          "
        >
          <p style="margin:0;font-size:0.8rem;color:var(--muted-foreground);">
            © {new Date().getFullYear()} FlowForm. Built with security in mind.
          </p>
          <div style="display:flex;align-items:center;gap:20px;">
            <span
              style="
                display:inline-flex;align-items:center;gap:5px;
                font-size:0.78rem;font-weight:600;
                color:rgb(22 163 74);
              "
            >
              <span style="width:7px;height:7px;border-radius:999px;background:rgb(22 163 74);display:inline-block;"></span>
              All systems operational
            </span>
            <span style="font-size:0.8rem;color:var(--muted-foreground);">Privacy · Terms · Cookies</span>
          </div>
        </div>
      </div>
    </footer>

  </main>
</Layout>

<style>
  /* Responsive grid overrides for smaller screens */
  @media (max-width: 768px) {
    #security > div > div {
      grid-template-columns: 1fr !important;
    }
    footer > div > div:first-child {
      grid-template-columns: 1fr 1fr !important;
    }
  }
  @media (max-width: 480px) {
    footer > div > div:first-child {
      grid-template-columns: 1fr !important;
    }
  }
</style>
