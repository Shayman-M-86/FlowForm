---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { NodePageIsland } from "../components/NodePageIsland";
import AnimatedApng from "../components/AnimatedApng.astro";
---

<Layout
  title="FlowForm | Build Forms and Surveys"
  description="Build branching surveys, scored quizzes, and research questionnaires in minutes. Five question types, visual logic rules, and privacy by design — free during beta."
>
  <SiteHeader />

  <main class="main-safe-top">
    <!-- ─── Hero ──────────────────────────────────────────────── -->
    <section id="hero" class="bg-hero-gradient px-6 pb-20 pt-24 text-center">
      <div class="mx-auto max-w-3xl">
        <div class="mb-6 inline-flex items-center gap-1.5 rounded-full border border-accent/20 bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-accent">
          <span class="inline-block size-1.5 rounded-full bg-accent"></span>
          Now in Beta · Free to use
        </div>

        <h1 class="mb-5 text-4xl font-extrabold leading-tight tracking-tight text-foreground md:text-6xl">
          FlowForm<br />
          <span class="text-primary">Forms that adapt to every answer.</span>
        </h1>

        <p class="mx-auto mb-9 max-w-xl text-base leading-relaxed text-muted-foreground md:text-xl">
          Build branching surveys, scored quizzes, and research questionnaires
          in your browser. Five question types, visual rules, and scoring logic
          — all from a clean visual interface.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href="#builder"
            class="inline-flex items-center gap-2 rounded-xl bg-primary px-7 py-3 text-sm font-semibold text-primary-foreground no-underline shadow-md transition-opacity hover:opacity-90"
          >
            Start building now →
          </a>
          <a
            href="#features"
            class="inline-flex items-center gap-2 rounded-xl bg-card px-7 py-3.5 text-sm font-semibold text-foreground no-underline shadow-sm transition-colors hover:bg-hover-highlight"
          >
            See features
          </a>
        </div>

        <!-- Social proof strip -->
        <div class="mt-14 flex flex-wrap items-stretch justify-center gap-3">
          {
            [
              {
                src: "/icons8-fast-48.apng.png",
                alt: "Timer",
                label: "Launch in minutes",
              },
              {
                src: "/icons8-settings-48.apng.png",
                alt: "Settings",
                label: "Visual logic builder",
              },
              {
                src: "/icons8-lock-48.apng.png",
                alt: "Lock",
                label: "Privacy by design",
              },
              {
                src: "/icons8-verified-account-48.apng.png",
                alt: "Verified",
                label: "Easy to use",
              },
            ].map(({ src, alt, label }) => (
              <span class="flex items-center gap-2 text-sm font-medium text-muted-foreground">
                <AnimatedApng src={src} alt={alt} width={20} height={20} />
                {label}
              </span>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── Builder ────────────────────────────────────────────── -->
    <section id="builder" class="border-y border-border bg-background">
      <!-- Builder label bar -->
      <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-6 pt-7">
        <div>
          <p class="mb-1 text-xs font-bold uppercase tracking-widest text-accent">
            Live builder
          </p>
          <h2 class="border-none p-0 text-2xl font-bold tracking-tight text-foreground md:text-3xl">
            Build your form, right here
          </h2>
        </div>
        <p class="max-w-md text-sm leading-normal text-muted-foreground">
          Everything auto-saves to your browser. Try adding a rule or rating
          scale.
        </p>
      </div>

      <!-- NodePage island — full React app embedded -->
      <NodePageIsland client:only="react">
        <div slot="fallback" class="builder-loading" aria-hidden="true">
          <div class="builder-loading__body">
            <div class="builder-loading__divider"></div>
            <div class="builder-loading__card">
              <div class="builder-loading__wave"></div>
            </div>
          </div>
        </div>
      </NodePageIsland>
    </section>

    <!-- ─── Question Types ─────────────────────────────────────── -->
    <section id="features" class="border-t border-border bg-background px-12 pb-10 pt-12">
      <div class="mx-auto max-w-7xl">
        <div class="mb-14">
          <p class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent">
            Question types
          </p>
          <h2 class="border-none p-0 text-3xl font-extrabold tracking-tight text-foreground md:text-4xl">
            Five building blocks. Infinite flows.
          </h2>
        </div>

        <div class="qt-track grid grid-cols-5 gap-6">
          {
            [
              {
                num: "01",
                title: "Multiple choice",
                body: "Single or multi-select, with optional numeric scores.",
                img: "/screenshots/qt-choice.apng",
              },
              {
                num: "02",
                title: "Matching",
                body: "Pair items between two columns for knowledge checks.",
                img: "/screenshots/qt-matching.png",
              },
              {
                num: "03",
                title: "Rating",
                body: "Numeric scales, sliders, or stars with configurable range.",
                img: "/screenshots/qt-rating.png",
              },
              {
                num: "04",
                title: "Open field",
                body: "Text, email, number, or date inputs for free-form answers.",
                img: "/screenshots/qt-field.png",
              },
              {
                num: "05",
                title: "Rules",
                body: "A logic node that branches the form based on previous answers.",
                img: "/screenshots/qt-rules.png",
              },
            ].map(({ num, title, body, img }) => (
              <div id={`qt-${num}`} class="qt-col flex flex-col">
                <div class="min-h-80 flex-1 overflow-hidden rounded-2xl bg-muted">
                  <img
                    src={img}
                    alt={title}
                    class="block h-full w-full object-cover"
                    loading="lazy"
                    onerror="this.style.display='none'"
                  />
                </div>
                <div class="pt-4">
                  <span class="mb-1.5 block text-xs font-extrabold uppercase tracking-widest text-accent">
                    {num}
                  </span>
                  <h3 class="mb-1.5 text-sm font-bold leading-tight text-foreground">
                    {title}
                  </h3>
                  <p class="text-sm leading-relaxed text-muted-foreground">
                    {body}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
        <nav class="qt-dots" aria-label="Question type slides">
          {
            ["01", "02", "03", "04", "05"].map((num) => (
              <a
                href={`#qt-${num}`}
                aria-label={`Show question type ${num}`}
                aria-current={num === "01" ? "true" : undefined}
              />
            ))
          }
        </nav>
      </div>
    </section>

    <!-- ─── Rules & adaptive logic ─────────────────────────────── -->
    <section id="logic" class="bg-logic-gradient border-t border-border px-6 py-20">
      <div class="logic-layout mx-auto grid max-w-5xl grid-cols-2 items-center gap-16">
        <div>
          <p class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent">
            Adaptive logic
          </p>
          <h2 class="mb-5 border-none p-0 text-3xl font-extrabold leading-tight tracking-tight text-foreground md:text-4xl">
            Your form branches.<br />Without code.
          </h2>
          <p class="mb-7 text-base leading-loose text-muted-foreground">
            Add a Rules node anywhere in your flow and set conditions like <em
              >equals</em
            >, <em>contains</em>, <em>between</em>, or <em>is answered</em>.
            Combine them with AND / OR / NOT to skip questions, show follow-ups,
            or change required fields — all from the visual builder.
          </p>
        </div>

        <div class="logic-cards flex flex-col gap-3.5">
          {
            [
              {
                src: "/icons8-settings-48.apng.png",
                alt: "Settings",
                label: "Grouped AND / OR / NOT conditions",
                detail: "Build nested logic trees — no code, no regex.",
              },
              {
                src: "/icons8-goal-48.apng.png",
                alt: "Target",
                label: "Show, hide, require, or disable",
                detail:
                  "Rules can drive four distinct effects on any question.",
              },
              {
                src: "/icons8-search-in-list-48.apng.png",
                alt: "List",
                label: "Deterministic conflict resolution",
                detail:
                  "Sort-keyed rule ordering means results are always predictable.",
              },
            ].map(({ src, alt, label, detail }, index) => (
              <div
                id={`logic-${index + 1}`}
                class="logic-card flex items-start gap-4 rounded-xl bg-card px-5 py-4 shadow-xs"
              >
                <div class="flex min-w-8 self-stretch items-center justify-center">
                  <AnimatedApng src={src} alt={alt} width={30} height={30} />
                </div>
                <div class="flex min-h-14 flex-col justify-center">
                  <p class="mb-1.5 text-sm font-bold text-foreground">
                    {label}
                  </p>
                  <p class="text-sm leading-relaxed text-muted-foreground">
                    {detail}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
        <nav class="logic-dots" aria-label="Adaptive logic slides">
          {
            [1, 2, 3].map((num) => (
              <a
                href={`#logic-${num}`}
                aria-label={`Show adaptive logic card ${num}`}
                aria-current={num === 1 ? "true" : undefined}
              />
            ))
          }
        </nav>
      </div>
    </section>

    <!-- ─── Scoring & export ───────────────────────────────────── -->
    <section id="scoring" class="border-t border-border bg-background px-6 py-24">
      <div class="mx-auto max-w-5xl">
        <div class="mb-14 text-center">
          <p class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent">
            For serious survey work
          </p>
          <h2 class="border-none p-0 text-3xl font-extrabold tracking-tight text-foreground md:text-4xl">
            Built for quizzes,<br />assessments, and research.
          </h2>
        </div>

        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
          {
            [
              {
                icon: (
                  <AnimatedApng
                    src="/icons8-question-48.apng.png"
                    alt="Scoring"
                    width={36}
                    height={36}
                  />
                ),
                title: "Scoring",
                body: "Score responses with multiple strategies — option-to-points, matching keys, rating values, or numeric-range buckets. Organize results into named buckets like total or risk.",
              },
              {
                icon: (
                  <AnimatedApng
                    src="/icons8-choice-48.apng.png"
                    alt="Export"
                    width={36}
                    height={36}
                  />
                ),
                title: "Open export",
                body: "Every form serializes to a clean SurveyNode[] JSON schema. Send it to your backend, your API, or your data pipeline — no lock-in, ever.",
              },
            ].map(({ icon, title, body }) => (
              <div class="relative overflow-hidden rounded-xl bg-card p-8 shadow-sm">
                <div class="mb-3 flex items-center gap-3.5">
                  {icon}
                  <h3 class="text-lg font-bold leading-tight text-foreground">
                    {title}
                  </h3>
                </div>
                <p class="max-w-sm text-sm leading-relaxed text-muted-foreground">
                  {body}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── Security ───────────────────────────────────────────── -->
    <section id="security" class="bg-security-gradient border-t border-border px-6 py-24">
      <div class="security-layout mx-auto grid max-w-5xl grid-cols-2 items-center gap-16">
        <!-- Left copy -->
        <div class="security-copy">
          <p class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent">
            Security first
          </p>
          <h2 class="mb-5 border-none p-0 text-3xl font-extrabold leading-tight tracking-tight text-foreground md:text-4xl">
            Your data is yours.<br />Full stop.
          </h2>
          <p class="mb-7 text-base leading-loose text-muted-foreground">
            FlowForm stores form structure and responses in two separate
            databases, with no cross-database foreign keys. Real user IDs never
            touch response data — only stable pseudonymous UUIDs. Every
            submission uses a two-phase write with rollback protection. Privacy
            is architectural, not aspirational.
          </p>

          <div class="flex flex-col gap-3.5">
            {
              [
                {
                  label: "Pseudonymous responses",
                  detail:
                    "Real user IDs never touch the response database — only stable anonymous UUIDs.",
                },
                {
                  label: "Dual-database isolation",
                  detail:
                    "Survey structure and raw responses live in separate databases with no cross-DB foreign keys.",
                },
                {
                  label: "Atomic saga writes",
                  detail:
                    "Submissions use a two-phase commit with automatic rollback. Partial writes are impossible.",
                },
                {
                  label: "GDPR-ready architecture",
                  detail:
                    "Right-to-erasure is straightforward: pseudonymous mappings can be deleted independently.",
                },
              ].map(({ label, detail }) => (
                <div class="flex items-start gap-3.5">
                  <div class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full bg-success/10">
                    <svg
                      class="size-3 stroke-success"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                  </div>
                  <div>
                    <p class="mb-0.5 text-sm font-semibold text-foreground">
                      {label}
                    </p>
                    <p class="text-sm leading-relaxed text-muted-foreground">
                      {detail}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Right: visual shield card -->
        <div class="shield-card flex flex-col items-center gap-7 rounded-xl bg-card px-9 py-10 shadow-lg">
          <div class="shield-icon-box flex size-20 items-center justify-center rounded-3xl bg-primary/10">
            <AnimatedApng
              src="/icons8-shield-96.apng.png"
              alt="Security shield"
              width={64}
              height={64}
            />
          </div>

          <div class="flex w-full flex-col gap-2.5">
            {
              [
                {
                  label: "Data encryption",
                  status: "Active",
                  tone: "text-success",
                },
                {
                  label: "Identity isolation",
                  status: "Active",
                  tone: "text-success",
                },
                {
                  label: "Audit logging",
                  status: "Active",
                  tone: "text-success",
                },
                {
                  label: "GDPR compliance",
                  status: "Ready",
                  tone: "text-primary",
                },
                {
                  label: "SOC 2 (coming soon)",
                  status: "Planned",
                  tone: "text-warning",
                },
              ].map(({ label, status, tone }) => (
                <div class="security-status-row flex items-center justify-between rounded-lg bg-muted px-3.5 py-2.5 text-sm">
                  <span class="font-medium text-foreground">{label}</span>
                  <span class:list={["text-xs font-semibold uppercase tracking-wide", tone]}>
                    ✓ {status}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ─── How it works ───────────────────────────────────────── -->
    <section class="border-t border-border bg-background px-6 py-24">
      <div class="mx-auto max-w-4xl text-center">
        <p class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent">
          How it works
        </p>
        <h2 class="mb-14 border-none p-0 text-3xl font-extrabold tracking-tight text-foreground md:text-4xl">
          From zero to live form in three steps
        </h2>

        <div class="grid grid-cols-1 gap-8 text-left md:grid-cols-3">
          {
            [
              {
                step: "01",
                title: "Drop in question nodes",
                body: "Choose from multiple choice, matching, rating, and open-field nodes. Arrange them into the flow your form needs.",
              },
              {
                step: "02",
                title: "Add a Rules node",
                body: "Set conditions like equals or between, combine them with AND / OR / NOT, and branch the flow automatically.",
              },
              {
                step: "03",
                title: "Preview, share, export",
                body: "Test the respondent experience end-to-end, share a link, or export the JSON schema for your own backend.",
              },
            ].map(({ step, title, body }) => (
              <div class="relative">
                <div class="mb-3 text-5xl font-black leading-none tracking-tighter text-accent/15">
                  {step}
                </div>
                <h3 class="mb-2.5 text-base font-bold text-foreground">
                  {title}
                </h3>
                <p class="text-sm leading-relaxed text-muted-foreground">
                  {body}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── CTA band ───────────────────────────────────────────── -->
    <section id="pricing" class="bg-cta-gradient border-t border-border px-6 py-20 text-center">
      <div class="mx-auto max-w-2xl">
        <h2 class="mb-4 border-none p-0 text-3xl font-extrabold tracking-tight text-foreground md:text-4xl">
          Ready to build smarter forms?
        </h2>
        <p class="mb-9 text-lg leading-relaxed text-muted-foreground">
          FlowForm is free during beta. No credit card. No time limit. Just open
          the builder above and start creating.
        </p>
        <a
          href="#builder"
          class="inline-flex items-center gap-2 rounded-xl bg-primary px-9 py-3.5 text-base font-bold text-primary-foreground no-underline shadow-lg transition-opacity hover:opacity-90"
        >
          Open the builder →
        </a>
        <p class="mt-5 text-sm text-muted-foreground">
          Auto-saves to your browser · Export anytime
        </p>
      </div>
    </section>

    <!-- ─── Footer ─────────────────────────────────────────────── -->
    <footer class="border-t border-border bg-card px-6 py-11 pb-0">
      <div class="mx-auto max-w-5xl">
        <!-- Top row -->
        <div class="site-footer-grid mb-14 grid gap-12">
          <!-- Brand column -->
          <div class="site-footer-brand justify-self-center pb-3">
            <div class="mb-4 flex items-center gap-2.5">
              <div class="flex size-8 items-center justify-center overflow-hidden rounded-lg">
                <img
                  src="/FlowForm_logo.png"
                  alt="FlowForm logo"
                  class="block h-full w-full object-contain"
                />
              </div>
              <span class="text-lg font-extrabold tracking-tight text-foreground">
                FlowForm
              </span>
            </div>
            <p class="mb-5 max-w-xs text-sm leading-loose text-muted-foreground">
              A security-first form and survey builder. Fast to set up, powerful
              enough for real research, private by design.
            </p>
            <!-- Security badges -->
            <div class="flex flex-wrap gap-2">
              {
                [
                  { apng: "/icons8-lock-48.apng.png", label: "Encrypted" },
                  { apng: "/icons8-shield-48.apng.png", label: "GDPR Ready" },
                ].map(({ apng, label }) => (
                  <span class="inline-flex items-center gap-1 rounded-full border border-border bg-muted px-2.5 py-1 text-xs font-semibold text-muted-foreground">
                    {apng ? (
                      <AnimatedApng
                        src={apng}
                        alt={label}
                        width={14}
                        height={14}
                      />
                    ) : null}
                    {label}
                  </span>
                ))
              }
            </div>
          </div>

          <!-- Product column -->
          <div class="site-footer-link-section">
            <p class="mb-4 text-xs font-bold uppercase tracking-wider text-foreground">
              Product
            </p>
            <ul class="site-footer-link-list flex list-none flex-col gap-2.5 p-0">
              {
                [
                  "Form Builder",
                  "Question Types",
                  "Adaptive Rules",
                  "Export & API",
                  "Preview Mode",
                ].map((item) => (
                  <li>
                    <a
                      href="#builder"
                      class="text-sm text-muted-foreground no-underline transition-colors hover:text-foreground"
                    >
                      {item}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Security column -->
          <div class="site-footer-link-section">
            <p class="mb-4 text-xs font-bold uppercase tracking-wider text-foreground">
              Security
            </p>
            <ul class="site-footer-link-list flex list-none flex-col gap-2.5 p-0">
              {
                [
                  "Privacy Policy",
                  "Data Isolation",
                  "GDPR Compliance",
                  "Audit Logs",
                  "Pseudonymity",
                ].map((item) => (
                  <li>
                    <a
                      href="#security"
                      class="text-sm text-muted-foreground no-underline transition-colors hover:text-foreground"
                    >
                      {item}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Company column -->
          <div class="site-footer-link-section">
            <p class="mb-4 text-xs font-bold uppercase tracking-wider text-foreground">
              Company
            </p>
            <ul class="site-footer-link-list flex list-none flex-col gap-2.5 p-0">
              {
                ["About", "Blog", "Changelog", "Status", "Contact"].map(
                  (item) => (
                    <li>
                      <a
                        href="#"
                        class="text-sm text-muted-foreground no-underline transition-colors hover:text-foreground"
                      >
                        {item}
                      </a>
                    </li>
                  ),
                )
              }
            </ul>
          </div>
        </div>

        <!-- Bottom row -->
        <div class="site-footer-bottom footer-bleed flex flex-wrap items-center justify-between gap-4 bg-background py-7 pb-10">
          <p class="text-sm text-muted-foreground">
            © {new Date().getFullYear()} FlowForm. Built with security in mind.
          </p>
          <div class="site-footer-bottom-links flex items-center gap-5">
            <span class="inline-flex items-center gap-1 text-xs font-semibold text-success">
              <span class="inline-block size-2 rounded-full bg-success"></span>
              All systems operational
            </span>
            <span class="text-sm text-muted-foreground">
              Privacy · Terms · Cookies
            </span>
          </div>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<script>
  const initCarouselDots = (
    trackSelector: string,
    cardSelector: string,
    dotSelector: string,
  ) => {
    const track = document.querySelector<HTMLElement>(trackSelector);
    const cards = Array.from(
      document.querySelectorAll<HTMLElement>(cardSelector),
    );
    const dots = Array.from(
      document.querySelectorAll<HTMLAnchorElement>(dotSelector),
    );

    if (!track || cards.length === 0 || dots.length === 0) return;

    const setActiveDot = () => {
      const trackCenter =
        track.getBoundingClientRect().left + track.clientWidth / 2;
      let activeIndex = 0;
      let activeDistance = Number.POSITIVE_INFINITY;

      cards.forEach((card, index) => {
        const rect = card.getBoundingClientRect();
        const cardCenter = rect.left + rect.width / 2;
        const distance = Math.abs(trackCenter - cardCenter);

        if (distance < activeDistance) {
          activeDistance = distance;
          activeIndex = index;
        }
      });

      dots.forEach((dot, index) => {
        if (index === activeIndex) {
          dot.setAttribute("aria-current", "true");
        } else {
          dot.removeAttribute("aria-current");
        }
      });
    };

    track.addEventListener(
      "scroll",
      () => requestAnimationFrame(setActiveDot),
      { passive: true },
    );
    window.addEventListener("resize", setActiveDot);

    dots.forEach((dot) => {
      dot.addEventListener("click", (event) => {
        event.preventDefault();

        const targetId = dot.getAttribute("href")?.slice(1);
        const target = targetId ? document.getElementById(targetId) : null;
        if (!target) return;

        const trackRect = track.getBoundingClientRect();
        const targetRect = target.getBoundingClientRect();
        const nextLeft =
          track.scrollLeft +
          targetRect.left -
          trackRect.left -
          (track.clientWidth - targetRect.width) / 2;

        track.scrollTo({ left: nextLeft, behavior: "smooth" });
      });
    });

    setActiveDot();
  };

  const initCarouselDotIndicators = () => {
    initCarouselDots(".qt-track", ".qt-col", ".qt-dots a");
    initCarouselDots(".logic-cards", ".logic-card", ".logic-dots a");
