---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { NodePageIsland } from "../components/NodePageIsland";
import AnimatedApng from "../components/AnimatedApng.astro";
import {
  Microscope,
  Trophy,
  Funnel,
  Users,
  PencilRuler,
  BookLock,
  Share2,
  Inbox,
  ClipboardList,
  RefreshCw,
} from "@lucide/astro";
---

<Layout
  title="FlowForm | Adaptive Survey Builder"
  description="Build adaptive surveys, scored quizzes, and research questionnaires with version-controlled publishing, team access, and privacy-aware response storage. Free during beta."
>
  <SiteHeader />

  <main class="main-safe-top" style="overflow-x: clip;">
    <!-- ─── Hero ──────────────────────────────────────────────── -->
    <section id="hero" class="bg-hero-gradient px-6 pb-15 pt-15 text-center">
      <div class="mx-auto max-w-4xl">
        <div
          class="mb-6 inline-flex items-center gap-1.5 rounded-full border border-accent/20 bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-accent"
        >
          <span class="inline-block size-1.5 rounded-full bg-accent"></span>
          Now in beta · Free to use
        </div>

        <h1
          class="mb-5 text-4xl font-extrabold leading-tight tracking-tight text-foreground md:text-5xl"
        >
          Build smarter surveys.<br />
          <span class="text-primary text-3xl md:text-4xl"
            >Protect the data behind them.</span
          >
        </h1>

        <p
          class="mx-auto mb-9 max-w-2xl text-base leading-relaxed text-muted-foreground md:text-xl"
        >
          Adaptive surveys with branching logic, versioned publishing, and
          privacy-aware storage.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href="#builder"
            class="ui-button-primary px-7 py-3 text-sm shadow-md"
          >
            Try the live builder →
          </a>
          <a
            href="#platform"
            class="ui-action inline-flex items-center gap-2 rounded-sm bg-card px-7 py-3.5 text-sm font-semibold text-foreground no-underline shadow-sm"
          >
            See how it works
          </a>
        </div>

        <div class="mt-8 grid grid-cols-2 gap-3 text-left md:grid-cols-4">
          {
            [
              {
                src: "/icons/icons8-fast-48.webp",
                alt: "Fast setup",
                label: "Launch faster",
                detail: "Create structured surveys without rebuilding logic.",
              },
              {
                src: "/icons/icons8-settings-48.webp",
                alt: "Version settings",
                label: "Publish safely",
                detail:
                  "Edit drafts and publish versions without rewriting history.",
              },
              {
                src: "/icons/icons8-verified-account-48.webp",
                alt: "Team access",
                label: "Control access",
                detail:
                  "Manage project and survey permissions across team roles.",
              },
              {
                src: "/icons/icons8-lock-48.webp",
                alt: "Privacy lock",
                label: "Isolate responses",
                detail:
                  "Separate core app data from raw response payloads by design.",
              },
            ].map(({ src, alt, label, detail }) => (
              <div class="rounded-xl border border-border/30 bg-card/30 p-4 shadow-md">
                <div class="mb-2 flex items-center gap-2">
                  <AnimatedApng src={src} alt={alt} width={22} height={22} />
                  <p class="text-sm font-bold text-foreground">{label}</p>
                </div>
                <p class="text-xs leading-relaxed text-muted-foreground">
                  {detail}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    
    <!-- ─── Builder ────────────────────────────────────────────── -->
    <section
    id="builder"
    class="relative overflow-hidden border-y border-border bg-background"
    >
    <div
    class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-6 pt-7"
    >
    <div>
      <p
      class="mb-1 text-xs font-bold uppercase tracking-widest text-accent"
      >
      Live builder
    </p>
    <h2
    class="border-none p-0 text-2xl font-bold tracking-tight text-foreground md:text-3xl"
    >
    Try the builder directly on the page
  </h2>
</div>
<p class="max-w-md text-sm leading-normal text-muted-foreground">
  Add questions, experiment with rules, and see how an adaptive survey
  takes shape. Your demo work auto-saves to the browser.
</p>
</div>

<NodePageIsland client:only="react">
  <div slot="fallback" class="builder-loading" aria-hidden="true">
    <div class="builder-loading__body">
      <div class="builder-loading__divider"></div>
      <div class="builder-loading__card">
        <div class="builder-loading__wave"></div>
      </div>
    </div>
  </div>
</NodePageIsland>
</section>

<!-- ─── Product promise ───────────────────────────────────── -->
<section id="why" class="border-t border-border bg-background px-6 py-20">
  <div
    class="mx-auto grid max-w-6xl gap-12 md:grid-cols-[0.9fr_1.1fr] md:items-center"
  >
    <div>
      <p
        class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent"
      >
        Why FlowForm
      </p>
      <h2
        class="mb-5 border-none p-0 text-3xl font-extrabold leading-tight tracking-tight text-foreground md:text-4xl"
      >
        Simple forms are easy.<br />Trustworthy data collection is harder.
      </h2>
      <p class="text-base leading-loose text-muted-foreground">
        Most form tools work well until surveys change, teams need access
        controls, or responses need to be traced back to the exact form that
        collected them. FlowForm is designed for that next level of control:
        adaptive forms, stable published versions, and a data model that
        keeps sensitive answers separated from account and project data.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        (
          [
            {
              Icon: Microscope,
              title: "For research workflows",
              body: "Build questionnaires that adapt to participant answers while preserving a clear version history.",
            },
            {
              Icon: Trophy,
              title: "For scored assessments",
              body: "Create quizzes and structured evaluations with scoring-ready question types and result groups.",
            },
            {
              Icon: Funnel,
              title: "For intake and screening",
              body: "Ask only the questions that matter using branching logic and conditional follow-ups.",
            },
            {
              Icon: Users,
              title: "For teams",
              body: "Organise surveys into projects and control who can build, publish, view, or manage access.",
            },
          ] as const
        ).map(({ Icon, title, body }) => (
          <div class="rounded-xl bg-card p-6 shadow-sm">
            <div class="mb-3 flex items-center gap-2.5 text-accent">
              <Icon size={18} stroke-width={1.75} />
              <h3 class="text-base font-bold text-foreground">{title}</h3>
            </div>
            <p class="text-sm leading-relaxed text-muted-foreground">
              {body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- ─── Question Types ─────────────────────────────────────── -->
<section
id="features"
class="border-t border-border bg-background px-12 pb-10 pt-16"
>
<div class="mx-auto max-w-7xl">
  <div class="mb-14 max-w-3xl">
    <p
    class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent"
    >
    Builder blocks
  </p>
          <h2
            class="mb-4 border-none p-0 text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
          >
            The building blocks for adaptive forms
          </h2>
          <p class="text-base leading-relaxed text-muted-foreground">
            Combine question nodes and rule nodes to build anything from a
            simple intake form to a scored quiz or branching research
            questionnaire.
          </p>
        </div>

        <div class="qt-track grid grid-cols-5 gap-6">
          {
            [
              {
                num: "01",
                title: "Choice",
                body: "Single-select and multi-select questions for preferences, eligibility checks, and scored answers.",
                img: "/screenshots/qt-choice.png",
              },
              {
                num: "02",
                title: "Matching",
                body: "Pair items across columns for knowledge checks, terminology tests, and association questions.",
                img: "/screenshots/qt-matching.png",
              },
              {
                num: "03",
                title: "Rating",
                body: "Use scales, sliders, or star-style ratings for Likert items, satisfaction scores, and quick assessments.",
                img: "/screenshots/qt-rating.png",
              },
              {
                num: "04",
                title: "Field",
                body: "Capture short text, numbers, dates, email addresses, and structured free-form responses.",
                img: "/screenshots/qt-field.png",
              },
              {
                num: "05",
                title: "Rules",
                body: "Branch the form with conditional logic using grouped AND / OR / NOT conditions.",
                img: "/screenshots/qt-rules.png",
              },
            ].map(({ num, title, body, img }) => (
              <div id={`qt-${num}`} class="qt-col flex flex-col">
                <div class="min-h-80 flex-1 overflow-hidden rounded-2xl bg-muted">
                  <img
                    src={img}
                    alt={title}
                    class="block h-full w-full object-cover"
                    loading="lazy"
                    onerror="this.style.display='none'"
                  />
                </div>
                <div class="pt-4">
                  <span class="mb-1.5 block text-xs font-extrabold uppercase tracking-widest text-accent">
                    {num}
                  </span>
                  <h3 class="mb-1.5 text-sm font-bold leading-tight text-foreground">
                    {title}
                  </h3>
                  <p class="text-sm leading-relaxed text-muted-foreground">
                    {body}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
        <nav class="qt-dots" aria-label="Question type slides">
          {
            ["01", "02", "03", "04", "05"].map((num) => (
              <a
                href={`#qt-${num}`}
                class="ui-action"
                aria-label={`Show question type ${num}`}
                aria-current={num === "01" ? "true" : undefined}
              />
            ))
          }
        </nav>
      </div>
    </section>

    <!-- ─── Adaptive logic ─────────────────────────────────────── -->
    <section
      id="logic"
      class="bg-logic-gradient border-t border-border px-6 py-20"
    >
      <div
        class="logic-layout mx-auto grid max-w-5xl grid-cols-2 items-center gap-16"
      >
        <div>
          <p
            class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent"
          >
            Adaptive logic
          </p>
          <h2
            class="mb-5 border-none p-0 text-3xl font-extrabold leading-tight tracking-tight text-foreground md:text-4xl"
          >
            Every respondent gets the path that fits them.
          </h2>
          <p class="mb-7 text-base leading-loose text-muted-foreground">
            Drop a Rules node anywhere in the flow and branch based on previous
            answers. Show follow-ups, skip irrelevant sections, make fields
            required only when needed, and keep the survey focused from start to
            finish.
          </p>
        </div>

        <div class="logic-cards flex flex-col gap-3.5">
          {
            [
              {
                src: "/icons/icons8-settings-48.webp",
                alt: "Conditions",
                label: "Grouped conditions",
                detail:
                  "Combine rules with AND / OR / NOT groups for more precise branching logic.",
              },
              {
                src: "/icons/icons8-goal-48.webp",
                alt: "Target",
                label: "Targeted question flow",
                detail:
                  "Show, hide, require, or skip downstream questions based on earlier answers.",
              },
              {
                src: "/icons/icons8-search-in-list-48.webp",
                alt: "Ordered list",
                label: "Predictable ordering",
                detail:
                  "Sort-keyed nodes keep question and rule order deterministic as surveys grow.",
              },
            ].map(({ src, alt, label, detail }, index) => (
              <div
                id={`logic-${index + 1}`}
                class="logic-card flex items-start gap-4 rounded-xl bg-card px-5 py-4 shadow-xs"
              >
                <div class="flex min-w-8 self-stretch items-center justify-center">
                  <AnimatedApng src={src} alt={alt} width={30} height={30} />
                </div>
                <div class="flex min-h-14 flex-col justify-center">
                  <p class="mb-1.5 text-sm font-bold text-foreground">
                    {label}
                  </p>
                  <p class="text-sm leading-relaxed text-muted-foreground">
                    {detail}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
        <nav class="logic-dots" aria-label="Adaptive logic slides">
          {
            [1, 2, 3].map((num) => (
              <a
                href={`#logic-${num}`}
                class="ui-action"
                aria-label={`Show adaptive logic card ${num}`}
                aria-current={num === 1 ? "true" : undefined}
              />
            ))
          }
        </nav>
      </div>
    </section>

    <!-- ─── Platform ───────────────────────────────────────────── -->
    <section
      id="platform"
      class="border-t border-border bg-background px-6 py-24"
    >
      <div class="mx-auto max-w-6xl">
        <div class="mb-14 max-w-3xl">
          <p
            class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent"
          >
            Platform workflow
          </p>
          <h2
            class="mb-4 border-none p-0 text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
          >
            From draft to published survey without losing control
          </h2>
          <p class="text-base leading-relaxed text-muted-foreground">
            FlowForm separates building, publishing, distribution, and response
            review into a clear workflow so teams can move quickly without
            compromising data integrity.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          {
            (
              [
                {
                  Icon: PencilRuler,
                  step: "01",
                  title: "Build a draft",
                  body: "Create questions, arrange the flow, add logic, and iterate safely before anything goes live.",
                },
                {
                  Icon: BookLock,
                  step: "02",
                  title: "Publish a version",
                  body: "Freeze a stable version of the survey so collected responses always point back to the exact schema respondents saw.",
                },
                {
                  Icon: Share2,
                  step: "03",
                  title: "Share public links",
                  body: "Distribute published surveys through public links while keeping management features inside Studio.",
                },
                {
                  Icon: Inbox,
                  step: "04",
                  title: "Collect responses",
                  body: "Respondents complete the form without needing an account, using the public form-filler experience.",
                },
                {
                  Icon: ClipboardList,
                  step: "05",
                  title: "Review submissions",
                  body: "View response metadata and submitted answers from the Studio dashboard.",
                },
                {
                  Icon: RefreshCw,
                  step: "06",
                  title: "Keep improving",
                  body: "Create future drafts and publish new versions without changing the meaning of historical responses.",
                },
              ] as const
            ).map(({ Icon, step, title, body }) => (
              <div class="rounded-xl bg-card p-7 shadow-sm">
                <div class="mb-4 flex items-center gap-3">
                  <div class="flex size-9 items-center justify-center rounded-lg bg-accent/10 text-accent">
                    <Icon size={18} stroke-width={1.75} />
                  </div>
                  <span class="text-2xl font-black leading-none tracking-tighter text-accent/25">
                    {step}
                  </span>
                </div>
                <h3 class="mb-2 text-base font-bold text-foreground">
                  {title}
                </h3>
                <p class="text-sm leading-relaxed text-muted-foreground">
                  {body}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── Studio features ────────────────────────────────────── -->
    <section
      id="studio"
      class="bg-studio-gradient border-t border-border px-6 py-24"
    >
      <div class="mx-auto max-w-5xl text-center">
        <p
          class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent"
        >
          Studio
        </p>
        <h2
          class="mx-auto mb-5 max-w-3xl border-none p-0 text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
        >
          A management dashboard for serious survey work
        </h2>
        <p
          class="mx-auto mb-14 max-w-2xl text-base leading-relaxed text-muted-foreground"
        >
          Studio is where authenticated users manage the full survey lifecycle:
          projects, surveys, versions, links, members, roles, and responses.
        </p>

        <div class="grid gap-5 text-left md:grid-cols-2">
          {
            [
              {
                icon: "/icons/icons8-settings-48.webp",
                alt: "Survey management",
                title: "Project and survey workspaces",
                body: "Organise surveys into projects, keep settings scoped, and give each team a focused workspace.",
              },
              {
                icon: "/icons/icons8-verified-account-48.webp",
                alt: "Roles",
                title: "Project and survey roles",
                body: "Control who can manage surveys, publish versions, view responses, or administer team access.",
              },
              {
                icon: "/icons/icons8-choice-48.webp",
                alt: "Responses",
                title: "Response review",
                body: "Review submitted responses while preserving the version and submission metadata behind each record.",
              },
              {
                icon: "/icons/icons8-question-48.webp",
                alt: "Scoring",
                title: "Assessment-ready structure",
                body: "Use choice, rating, matching, and field questions as a foundation for scored quizzes and structured evaluations.",
              },
            ].map(({ icon, alt, title, body }) => (
              <div class="rounded-xl bg-card p-8 shadow-sm">
                <div class="mb-3 flex items-center gap-3.5">
                  <AnimatedApng src={icon} alt={alt} width={36} height={36} />
                  <h3 class="text-lg font-bold leading-tight text-foreground">
                    {title}
                  </h3>
                </div>
                <p class="text-sm leading-relaxed text-muted-foreground">
                  {body}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── Security / privacy architecture ────────────────────── -->
    <section
      id="security"
      class="bg-security-gradient border-t border-border px-6 py-24"
    >
      <div
        class="security-layout mx-auto grid max-w-5xl grid-cols-2 items-center gap-16"
      >
        <div class="security-copy">
          <p
            class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent"
          >
            Privacy-aware architecture
          </p>
          <h2
            class="mb-5 border-none p-0 text-3xl font-extrabold leading-tight tracking-tight text-foreground md:text-4xl"
          >
            Sensitive answers should not live beside identity data.
          </h2>
          <p class="mb-7 text-base leading-loose text-muted-foreground">
            FlowForm uses a two-database model. Core application data lives in
            one database, while raw response payloads live in a separate
            response database. Responses link back to submission metadata
            through a logical submission ID instead of direct user identifiers.
          </p>

          <div class="flex flex-col gap-3.5">
            {
              [
                {
                  label: "Core data stays separate",
                  detail:
                    "Projects, surveys, versions, roles, links, and submission metadata live in the core database.",
                },
                {
                  label: "Response payloads are isolated",
                  detail:
                    "Raw answers live in the response database, linked through core_submission_id rather than cross-database foreign keys.",
                },
                {
                  label: "Pseudonymous respondent IDs",
                  detail:
                    "The response database avoids storing real user IDs, supporting a cleaner privacy boundary.",
                },
                {
                  label: "Explicit service orchestration",
                  detail:
                    "Cross-database workflows are handled deliberately in the service layer instead of being hidden in model relationships.",
                },
              ].map(({ label, detail }) => (
                <div class="flex items-start gap-3.5">
                  <div class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full bg-success/10">
                    <svg
                      class="size-3 stroke-success"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                  </div>
                  <div>
                    <p class="mb-0.5 text-sm font-semibold text-foreground">
                      {label}
                    </p>
                    <p class="text-sm leading-relaxed text-muted-foreground">
                      {detail}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="shield-card flex flex-col items-center gap-7 rounded-xl bg-card px-9 py-10 shadow-lg"
        >
          <div
            class="shield-icon-box flex size-20 items-center justify-center rounded-3xl bg-primary/10"
          >
            <AnimatedApng
              src="/icons/icons8-shield-96.webp"
              alt="Security shield"
              width={64}
              height={64}
            />
          </div>

          <div class="w-full rounded-xl bg-muted p-5 text-left">
            <p
              class="mb-2 text-xs font-bold uppercase tracking-widest text-accent"
            >
              Data boundary
            </p>
            <div class="space-y-3 text-sm">
              <div class="rounded-lg bg-card p-4 shadow-xs">
                <p class="mb-1 font-bold text-foreground">Core database</p>
                <p class="leading-relaxed text-muted-foreground">
                  Users, projects, surveys, versions, permissions, links, and
                  submission metadata.
                </p>
              </div>
              <div
                class="flex justify-center text-xs font-bold uppercase tracking-widest text-muted-foreground"
              >
                linked by core_submission_id
              </div>
              <div class="rounded-lg bg-card p-4 shadow-xs">
                <p class="mb-1 font-bold text-foreground">Response database</p>
                <p class="leading-relaxed text-muted-foreground">
                  Raw answers and response payloads without direct real-user
                  identifiers.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Technical foundations ──────────────────────────────── -->
    <section
      id="technical"
      class="border-t border-border bg-background px-6 py-24"
    >
      <div class="mx-auto max-w-6xl">
        <div class="mb-14 grid gap-8 md:grid-cols-[0.9fr_1.1fr] md:items-end">
          <div>
            <p
              class="mb-2.5 text-xs font-bold uppercase tracking-widest text-accent"
            >
              Technical foundations
            </p>
            <h2
              class="border-none p-0 text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
            >
              Built like a product, not a prototype
            </h2>
          </div>
          <p class="text-base leading-relaxed text-muted-foreground">
            FlowForm combines a fast public site, a React management dashboard,
            shared frontend packages, and a Flask API with generated OpenAPI
            contracts so the platform can grow without losing structure.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          <div class="overflow-hidden rounded-xl bg-card shadow-sm">
            <div class="bg-agnostic px-5 pb-2 pt-3">
            <p
              class="mb-2 text-xs font-bold uppercase tracking-widest text-accent"
            >
              Frontend
            </p>
            <div class="flex items-center justify-between gap-2">
              <h3 class="text-lg font-bold text-foreground">Astro + React</h3>
              <div class="flex items-center gap-2">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 128 128"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-label="Astro logo"
                >
                  <defs>
                    <linearGradient
                      id="astro-logo-body"
                      x1="882.997"
                      x2="638.955"
                      y1="27.113"
                      y2="866.902"
                      gradientTransform="scale(.1)"
                      gradientUnits="userSpaceOnUse"
                    >
                      <stop offset="0" stop-color="#000014"></stop>
                      <stop offset="1" stop-color="#150426"></stop>
                    </linearGradient>
                    <linearGradient
                      id="astro-logo-flame"
                      x1="1001.68"
                      x2="790.326"
                      y1="652.45"
                      y2="1094.91"
                      gradientTransform="scale(.1)"
                      gradientUnits="userSpaceOnUse"
                    >
                      <stop offset="0" stop-color="#ff1639"></stop>
                      <stop offset="1" stop-color="#ff1639" stop-opacity="0"
                      ></stop>
                    </linearGradient>
                  </defs>
