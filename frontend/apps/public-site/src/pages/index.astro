---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { NodePageIsland } from '../components/NodePageIsland';
import AnimatedApng from '../components/AnimatedApng.astro';
---

<Layout title="FlowForm — Adaptive Forms, No Code">
  <SiteHeader />

  <main style="padding-top: 56px;">

    <!-- ─── Hero ──────────────────────────────────────────────── -->
    <section
      id="hero"
      style="
        text-align: center;
        padding: 80px 24px 60px;
        background: linear-gradient(
          160deg,
          var(--background) 0%,
          rgb(110 164 226 / 0.06) 50%,
          var(--background) 100%
        );
      "
    >
      <div style="max-width: 720px; margin: 0 auto;">
        <div
          style="
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 0.07em;
            text-transform: uppercase;
            color: var(--accent);
            background: rgb(110 164 226 / 0.1);
            border: 1px solid rgb(110 164 226 / 0.22);
            padding: 4px 12px;
            border-radius: 999px;
            margin-bottom: 24px;
          "
        >
          <span style="width:6px;height:6px;border-radius:999px;background:var(--accent);display:inline-block;"></span>
          Now in Beta · Free to use
        </div>

        <h1
          style="
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1.1;
            color: var(--foreground);
            margin: 0 0 20px;
          "
        >
          FlowForm<br />
          <span style="color: var(--primary);">Forms that adapt to every answer.</span>
        </h1>

        <p
          style="
            font-size: clamp(1rem, 2.2vw, 1.2rem);
            color: var(--muted-foreground);
            line-height: 1.65;
            margin: 0 auto 36px;
            max-width: 560px;
          "
        >
          Build branching surveys, scored quizzes, and research questionnaires in your browser.
          Five question types, visual rules, and scoring logic — all from a clean visual interface.
        </p>

        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          <a
            href="#builder"
            style="
              display: inline-flex;
              align-items: center;
              gap: 8px;
              font-size: 0.95rem;
              font-weight: 600;
              color: var(--primary-foreground);
              background: var(--primary);
              padding: 12px 28px;
              border-radius: var(--radius-xl);
              text-decoration: none;
              box-shadow: var(--app-shadow-md);
              transition: opacity 0.15s;
            "
          >
            Start building now →
          </a>
          <a
            href="#features"
            style="
              display: inline-flex;
              align-items: center;
              gap: 8px;
              font-size: 0.95rem;
              font-weight: 500;
              color: var(--foreground);
              background: var(--card);
              padding: 12px 28px;
              border-radius: var(--radius-xl);
              text-decoration: none;
              border: 1px solid var(--border);
              box-shadow: var(--app-shadow-sm);
              transition: background 0.15s;
            "
          >
            See features
          </a>
        </div>

        <!-- Social proof strip -->
        <div
          style="
            margin-top: 52px;
            display: flex;
            align-items: stretch;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
          "
        >
          {[
            { src: '/icons8-fast-48.apng.png', alt: 'Timer', label: 'Launch in minutes' },
            { src: '/icons8-settings-48.apng.png', alt: 'Settings', label: 'Visual logic builder' },
            { src: '/icons8-lock-48.apng.png', alt: 'Lock', label: 'Privacy by design' },
            { src: '/icons8-verified-account-48.apng.png', alt: 'Verified', label: 'Easy to use' },
          ].map(({ src, alt, label }) => (
            <span style="display:flex;align-items:center;gap:7px;font-size:0.82rem;font-weight:500;color:var(--muted-foreground);">
              <AnimatedApng src={src} alt={alt} width={20} height={20} />
              {label}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── Builder ────────────────────────────────────────────── -->
    <section
      id="builder"
      style="
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        background: var(--background);
      "
    >
      <!-- Builder label bar -->
      <div
        style="
          max-width: 1080px;
          margin: 0 auto;
          padding: 28px 24px 0;
          display: flex;
          align-items: center;
          justify-content: space-between;
          flex-wrap: wrap;
          gap: 12px;
        "
      >
        <div>
          <p
            style="
              margin: 0;
              font-size: 0.75rem;
              font-weight: 700;
              letter-spacing: 0.08em;
              text-transform: uppercase;
              color: var(--accent);
              margin-bottom: 4px;
            "
          >
            Live builder
          </p>
          <h2
            style="
              margin: 0;
              font-size: clamp(1.3rem, 3vw, 1.8rem);
              font-weight: 700;
              letter-spacing: -0.02em;
              color: var(--foreground);
              border: none;
              padding: 0;
            "
          >
            Build your form, right here
          </h2>
        </div>
        <p style="margin:0;font-size:0.88rem;color:var(--muted-foreground);max-width:420px;line-height:1.5;">
          Everything auto-saves to your browser. Try adding a rule or rating scale.
        </p>
      </div>

      <!-- NodePage island — full React app embedded -->
      <NodePageIsland client:only="react">
        <div slot="fallback" class="builder-loading" aria-hidden="true">
          <div class="builder-loading__body">
            <div class="builder-loading__divider"></div>
            <div class="builder-loading__card">
              <div class="builder-loading__wave"></div>
            </div>
          </div>
        </div>
      </NodePageIsland>
    </section>


    <!-- ─── Question Types ─────────────────────────────────────── -->
    <section
      id="features"
      style="
        padding: 120px 48px 140px;
        background: var(--background);
        border-top: 1px solid var(--border);
      "
    >
      <div style="max-width: 1400px; margin: 0 auto;">
        <div style="margin-bottom:56px;">
          <p style="margin:0 0 10px;font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--accent);">
            Question types
          </p>
          <h2
            style="
              margin:0;
              font-size:clamp(1.6rem,3.5vw,2.4rem);
              font-weight:800;
              letter-spacing:-0.025em;
              color:var(--foreground);
              border:none;padding:0;
            "
          >
            Five building blocks. Infinite flows.
          </h2>
        </div>

        <div
          style="
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 24px;
          "
        >
          {[
            {
              num: '01',
              title: 'Multiple choice',
              body: 'Single or multi-select, with optional numeric scores.',
              img: '/screenshots/qt-choice.apng',
            },
            {
              num: '02',
              title: 'Matching',
              body: 'Pair items between two columns for knowledge checks.',
              img: '/screenshots/qt-matching.png',
            },
            {
              num: '03',
              title: 'Rating',
              body: 'Numeric scales, sliders, or stars with configurable range.',
              img: '/screenshots/qt-rating.png',
            },
            {
              num: '04',
              title: 'Open field',
              body: 'Text, email, number, or date inputs for free-form answers.',
              img: '/screenshots/qt-field.png',
            },
            {
              num: '05',
              title: 'Rules',
              body: 'A logic node that branches the form based on previous answers.',
              img: '/screenshots/qt-rules.png',
            },
          ].map(({ num, title, body, img }) => (
            <div
              class="qt-col"
              style="
                display: flex;
                flex-direction: column;
              "
            >
              <div
                style="
                  flex: 1;
                  border-radius: 14px;
                  overflow: hidden;
                  background: var(--muted);
                  min-height: 320px;
                "
              >
                <img
                  src={img}
                  alt={title}
                  style="width:100%;height:100%;object-fit:cover;display:block;"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
              </div>
              <div style="padding-top:16px;">
                <span
                  style="
                    display:block;
                    font-size: 0.65rem;
                    font-weight: 800;
                    letter-spacing: 0.1em;
                    color: var(--accent);
                    text-transform: uppercase;
                    margin-bottom: 6px;
                  "
                >{num}</span>
                <h3
                  style="
                    margin: 0 0 6px;
                    font-size: 0.92rem;
                    font-weight: 700;
                    color: var(--foreground);
                    line-height: 1.3;
                  "
                >{title}</h3>
                <p
                  style="
                    margin: 0;
                    font-size: 0.8rem;
                    color: var(--muted-foreground);
                    line-height: 1.55;
                  "
                >{body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── Rules & adaptive logic ─────────────────────────────── -->
    <section
      id="logic"
      style="
        padding: 100px 24px;
        border-top: 1px solid var(--border);
        background: linear-gradient(
          135deg,
          var(--background) 0%,
          rgb(110 164 226 / 0.04) 100%
        );
      "
    >
      <div style="max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;">
        <div>
          <p style="margin:0 0 10px;font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--accent);">
            Adaptive logic
          </p>
          <h2
            style="
              margin:0 0 20px;
              font-size:clamp(1.6rem,3vw,2.2rem);
              font-weight:800;
              letter-spacing:-0.025em;
              color:var(--foreground);
              border:none;padding:0;line-height:1.2;
            "
          >
            Your form branches.<br />Without code.
          </h2>
          <p style="margin:0 0 28px;color:var(--muted-foreground);font-size:1rem;line-height:1.7;">
            Add a Rules node anywhere in your flow and set conditions like <em>equals</em>, <em>contains</em>, <em>between</em>, or <em>is answered</em>. Combine them with AND / OR / NOT to skip questions, show follow-ups, or change required fields — all from the visual builder.
          </p>
        </div>

        <div style="display:flex;flex-direction:column;gap:14px;">
          {[
            { src: '/icons8-settings-48.apng.png', alt: 'Settings', label: 'Grouped AND / OR / NOT conditions', detail: 'Build nested logic trees — no code, no regex.' },
            { src: '/icons8-goal-48.apng.png', alt: 'Target', label: 'Show, hide, require, or disable', detail: 'Rules can drive four distinct effects on any question.' },
            { src: '/icons8-search-in-list-48.apng.png', alt: 'List', label: 'Deterministic conflict resolution', detail: 'Sort-keyed rule ordering means results are always predictable.' },
          ].map(({ src, alt, label, detail }) => (
            <div
              style="
                display:flex;gap:16px;align-items:flex-start;
                padding:18px 20px;
                background:var(--card);
                border:1px solid var(--border);
                border-radius:14px;
                box-shadow:var(--app-shadow-xs);
              "
            >
              <div
                style="
                  width:30px;
                  min-width:30px;
                  align-self:stretch;
                  display:flex;
                  align-items:center;
                  justify-content:center;
                "
              >
                <AnimatedApng src={src} alt={alt} width={30} height={30} />
              </div>
              <div style="display:flex;flex-direction:column;justify-content:center;min-height:calc(0.92rem + 6px + (0.83rem * 1.55));">
                <p style="margin:0 0 6px;font-size:0.92rem;font-weight:700;color:var(--foreground);">
                  {label}
                </p>
                <p style="margin:0;font-size:0.83rem;color:var(--muted-foreground);line-height:1.55;">
                  {detail}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── Scoring & export ───────────────────────────────────── -->
    <section
      id="scoring"
      style="
        padding: 100px 24px;
        border-top: 1px solid var(--border);
        background: var(--background);
      "
    >
      <div style="max-width: 1080px; margin: 0 auto;">
        <div style="text-align:center;margin-bottom:56px;">
          <p style="margin:0 0 10px;font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--accent);">
            For serious survey work
          </p>
          <h2
            style="
              margin:0 0 16px;
              font-size:clamp(1.6rem,3.5vw,2.4rem);
              font-weight:800;
              letter-spacing:-0.025em;
              color:var(--foreground);
              border:none;padding:0;
            "
          >
            Built for quizzes,<br />assessments, and research.
          </h2>
        </div>

        <div
          style="
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 20px;
          "
        >
          {[
            {
              icon: <AnimatedApng src="/icons8-question-48.apng.png" alt="Scoring" width={36} height={36} />,
              title: 'Scoring',
              body: 'Score responses with multiple strategies — option-to-points, matching keys, rating values, or numeric-range buckets. Organize results into named buckets like total or risk.',
            },
            {
              icon: <AnimatedApng src="/icons8-choice-48.apng.png" alt="Export" width={36} height={36} />,
              title: 'Open export',
              body: 'Every form serializes to a clean SurveyNode[] JSON schema. Send it to your backend, your API, or your data pipeline — no lock-in, ever.',
            },
          ].map(({ icon, title, body }) => (
            <div
              style="
                padding: 32px;
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 18px;
                box-shadow: var(--app-shadow-sm);
                position: relative;
                overflow: hidden;
              "
            >
              <div style="display:flex;align-items:center;gap:14px;margin:0 0 12px;">
                {icon}
                <h3 style="margin:0;font-size:1.15rem;font-weight:700;color:var(--foreground);line-height:1.3;">{title}</h3>
              </div>
              <p style="margin:0;font-size:0.92rem;color:var(--muted-foreground);line-height:1.65;max-width:380px;">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── Security ───────────────────────────────────────────── -->
    <section
      id="security"
      style="
        padding: 100px 24px;
        background: linear-gradient(
          135deg,
          rgb(80 145 220 / 0.04) 0%,
          var(--background) 60%
        );
        border-top: 1px solid var(--border);
      "
    >
      <div style="max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;">
        <!-- Left copy -->
        <div>
          <p style="margin:0 0 10px;font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--accent);">
            Security first
          </p>
          <h2
            style="
              margin:0 0 20px;
              font-size:clamp(1.6rem,3vw,2.2rem);
              font-weight:800;
              letter-spacing:-0.025em;
              color:var(--foreground);
              border:none;padding:0;line-height:1.2;
            "
          >
            Your data is yours.<br />Full stop.
          </h2>
          <p style="margin:0 0 28px;color:var(--muted-foreground);font-size:1rem;line-height:1.7;">
            FlowForm stores form structure and responses in two separate databases, with no
            cross-database foreign keys. Real user IDs never touch response data — only
            stable pseudonymous UUIDs. Every submission uses a two-phase write with rollback
            protection. Privacy is architectural, not aspirational.
          </p>

          <div style="display:flex;flex-direction:column;gap:14px;">
            {[
              { label: 'Pseudonymous responses', detail: 'Real user IDs never touch the response database — only stable anonymous UUIDs.' },
              { label: 'Dual-database isolation', detail: 'Survey structure and raw responses live in separate databases with no cross-DB foreign keys.' },
              { label: 'Atomic saga writes', detail: 'Submissions use a two-phase commit with automatic rollback. Partial writes are impossible.' },
              { label: 'GDPR-ready architecture', detail: 'Right-to-erasure is straightforward: pseudonymous mappings can be deleted independently.' },
            ].map(({ label, detail }) => (
              <div style="display:flex;gap:14px;align-items:flex-start;">
                <div
                  style="
                    flex-shrink:0;
                    width:22px;height:22px;
                    border-radius:999px;
                    background:rgb(22 163 74 / 0.12);
                    display:flex;align-items:center;justify-content:center;
                    margin-top:2px;
                  "
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="rgb(22 163 74)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </div>
                <div>
                  <p style="margin:0 0 2px;font-size:0.9rem;font-weight:600;color:var(--foreground);">{label}</p>
                  <p style="margin:0;font-size:0.83rem;color:var(--muted-foreground);line-height:1.55;">{detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: visual shield card -->
        <div
          class="shield-card"
          style="
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 40px 36px;
            box-shadow: var(--app-shadow-lg);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 28px;
          "
        >
          <div
            style="
              width: 80px;height:80px;
              border-radius: 24px;
              background: linear-gradient(135deg, rgb(80 145 220 / 0.15), rgb(110 164 226 / 0.08));
              border: 1px solid rgb(110 164 226 / 0.2);
              display:flex;align-items:center;justify-content:center;
            "
          >
            <AnimatedApng src="/icons8-shield-96.apng.png" alt="Security shield" width={64} height={64} />
          </div>

          <div style="width:100%;display:flex;flex-direction:column;gap:10px;">
            {[
              { label: 'Data encryption', status: 'Active', color: 'rgb(22 163 74)' },
              { label: 'Identity isolation', status: 'Active', color: 'rgb(22 163 74)' },
              { label: 'Audit logging', status: 'Active', color: 'rgb(22 163 74)' },
              { label: 'GDPR compliance', status: 'Ready', color: 'rgb(80 145 220)' },
              { label: 'SOC 2 (coming soon)', status: 'Planned', color: 'rgb(202 138 4)' },
            ].map(({ label, status, color }) => (
              <div
                style="
                  display:flex;align-items:center;justify-content:space-between;
                  padding:10px 14px;
                  background:var(--muted);
                  border-radius:10px;
                  font-size:0.85rem;
                "
              >
                <span style="font-weight:500;color:var(--foreground);">{label}</span>
                <span
                  style={`
                    font-weight:600;
                    color:${color};
                    font-size:0.78rem;
                    letter-spacing:0.04em;
                  `}
                >
                  ✓ {status}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── How it works ───────────────────────────────────────── -->
    <section
      style="
        padding: 100px 24px;
        border-top: 1px solid var(--border);
        background: var(--background);
      "
    >
      <div style="max-width: 860px; margin: 0 auto; text-align: center;">
        <p style="margin:0 0 10px;font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--accent);">
          How it works
        </p>
        <h2
          style="
            margin:0 0 56px;
            font-size:clamp(1.6rem,3.5vw,2.4rem);
            font-weight:800;
            letter-spacing:-0.025em;
            color:var(--foreground);
            border:none;padding:0;
          "
        >
          From zero to live form in three steps
        </h2>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:32px;text-align:left;">
          {[
            {
              step: '01',
              title: 'Drop in question nodes',
              body: 'Choose from multiple choice, matching, rating, and open-field nodes. Arrange them into the flow your form needs.',
            },
            {
              step: '02',
              title: 'Add a Rules node',
              body: 'Set conditions like equals or between, combine them with AND / OR / NOT, and branch the flow automatically.',
            },
            {
              step: '03',
              title: 'Preview, share, export',
              body: 'Test the respondent experience end-to-end, share a link, or export the JSON schema for your own backend.',
            },
          ].map(({ step, title, body }) => (
            <div style="position:relative;">
              <div
                style="
                  font-size:3rem;
                  font-weight:900;
                  letter-spacing:-0.04em;
                  color:rgb(110 164 226 / 0.15);
                  line-height:1;
                  margin-bottom:12px;
                "
              >
                {step}
              </div>
              <h3 style="margin:0 0 10px;font-size:1rem;font-weight:700;color:var(--foreground);">{title}</h3>
              <p style="margin:0;font-size:0.875rem;color:var(--muted-foreground);line-height:1.6;">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CTA band ───────────────────────────────────────────── -->
    <section
      id="pricing"
      style="
        padding: 80px 24px;
        border-top: 1px solid var(--border);
        background: linear-gradient(
          135deg,
          rgb(80 145 220 / 0.08) 0%,
          rgb(110 164 226 / 0.04) 100%
        );
        text-align: center;
      "
    >
      <div style="max-width:600px;margin:0 auto;">
        <h2
          style="
            margin:0 0 16px;
            font-size:clamp(1.6rem,4vw,2.4rem);
            font-weight:800;
            letter-spacing:-0.025em;
            color:var(--foreground);
            border:none;padding:0;
          "
        >
          Ready to build smarter forms?
        </h2>
        <p style="margin:0 0 36px;font-size:1.05rem;color:var(--muted-foreground);line-height:1.6;">
          FlowForm is free during beta. No credit card. No time limit.
          Just open the builder above and start creating.
        </p>
        <a
          href="#builder"
          style="
            display:inline-flex;
            align-items:center;
            gap:8px;
            font-size:1rem;
            font-weight:700;
            color:var(--primary-foreground);
            background:var(--primary);
            padding:14px 36px;
            border-radius:var(--radius-xl);
            text-decoration:none;
            box-shadow:var(--app-shadow-lg);
            transition:opacity 0.15s;
          "
        >
          Open the builder →
        </a>
        <p style="margin:20px 0 0;font-size:0.82rem;color:var(--muted-foreground);">
          Auto-saves to your browser · Export anytime
        </p>
      </div>
    </section>


    <!-- ─── Footer ─────────────────────────────────────────────── -->
    <footer
      style="
        border-top: 1px solid var(--border);
        background: var(--card);
        padding: 64px 24px 40px;
      "
    >
      <div style="max-width:1080px;margin:0 auto;">
        <!-- Top row -->
        <div
          style="
            display:grid;
            grid-template-columns:2fr 1fr 1fr 1fr;
