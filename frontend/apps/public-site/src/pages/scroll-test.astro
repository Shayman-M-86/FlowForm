---
// Scroll test — plain fixed header, no framework magic
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#f7f7f7" />
    <title>Scroll Test</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { width: 100%; overflow-x: clip; background: #f7f7f7; }

      .header {
        position: fixed;
        left: 0; right: 0; top: 0;
        z-index: 50;
        /* Total height covers safe area + nav bar */
        height: calc(env(safe-area-inset-top) + 56px);
        padding-top: env(safe-area-inset-top);
        /* Solid at very top (island), fades to translucent at nav bar bottom */
        background: linear-gradient(
          to bottom,
          #f7f7f7 0%,
          rgb(247 247 247 / 0.15) 100%
        );
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        display: flex;
        align-items: flex-end;
        padding-inline: 20px;
        padding-bottom: 12px;
        color: #333;
        font: 700 1rem sans-serif;
        border-bottom: 1px solid rgb(0 0 0 / 0.08);
      }

      main {
        padding-top: calc(env(safe-area-inset-top) + 56px);
      }

      .row {
        height: 60px;
        display: flex;
        align-items: center;
        padding-inline: 24px;
        font: 700 1rem sans-serif;
      }

      .debug {
        position: fixed;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        background: black;
        color: lime;
        font: 700 13px monospace;
        padding: 8px 16px;
        border-radius: 999px;
        z-index: 999;
        white-space: nowrap;
      }
    </style>
  </head>
  <body>
    <div class="header">Fixed Header</div>

    <main id="main"></main>

    <div class="debug" id="debug">scrollY: 0</div>

    <script is:inline>
      const main = document.getElementById('main');
      const debug = document.getElementById('debug');

      // Build rows in JS to avoid Astro template issues
      for (let i = 0; i < 80; i++) {
        const row = document.createElement('div');
        row.className = 'row';
        row.style.background = `hsl(${i * 9} 60% 70%)`;
        row.textContent = `Row ${i + 1}`;
        main.appendChild(row);
      }

      window.addEventListener('scroll', () => {
        debug.textContent = 'scrollY: ' + Math.round(window.scrollY) + 'px';
      }, { passive: true });
    </script>
  </body>
</html>
