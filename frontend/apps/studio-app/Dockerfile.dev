FROM node:24-alpine

WORKDIR /app

# Copy workspace manifests first for better layer caching
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/studio-app/package.json ./apps/studio-app/
COPY packages/builder/package.json ./packages/builder/
COPY packages/schema/package.json ./packages/schema/
COPY packages/site-shell/package.json ./packages/site-shell/
COPY packages/styles/package.json ./packages/styles/
COPY packages/ui/package.json ./packages/ui/

RUN corepack enable && pnpm install --frozen-lockfile

# Copy the rest of the source
COPY . .

WORKDIR /app/apps/studio-app

EXPOSE 5174

CMD ["pnpm", "exec", "vite", "--host", "0.0.0.0", "--port", "5174"]
