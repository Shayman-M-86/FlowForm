{
  "name": "@flowform/studio-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "openapi:export": "bash ../../../backend/scripts/export-openapi.sh",
    "openapi:types": "openapi-typescript ../../../backend/openapi.yaml -o src/api/generated/schema.ts --root-types --root-types-no-schema-prefix",
    "openapi:generate": "pnpm run openapi:export && pnpm run openapi:types && pnpm --dir ../.. run generate:types",
    "openapi:check": "pnpm run openapi:export -- --check && openapi-typescript ../../../backend/openapi.yaml -o src/api/generated/schema.ts --root-types --root-types-no-schema-prefix --check",
    "preview": "vite preview",
    "routes": "tsr generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.16.1",
    "@flowform/builder": "workspace:*",
    "@flowform/schema": "workspace:*",
    "@flowform/site-shell": "workspace:*",
    "@flowform/styles": "workspace:*",
    "@flowform/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/query-persist-client-core": "^5.100.14",
    "@tanstack/react-query": "^5.80.2",
    "@tanstack/react-query-devtools": "^5.80.2",
    "@tanstack/react-router": "^1.121.2",
    "@tanstack/router-devtools": "^1.121.2",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.56.4",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^4.2.2",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@pinegrow/piny-vite": "^1.0.10",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.121.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.7"
  }
}
