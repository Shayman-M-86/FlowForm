{
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:studio": "npm --workspace apps/studio-app run dev",
        "dev:site": "npm --workspace apps/public-site run dev",
        "build:studio": "npm --workspace apps/studio-app run build",
        "build:site": "npm --workspace apps/public-site run build",
        "generate:types": "node scripts/generate-types.mjs"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "openapi-typescript": "^7.13.0",
        "typescript": "^5.0.0",
        "vite": "^8.0.10"
    }
}
