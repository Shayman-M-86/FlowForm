{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@flowform/styles": ["../styles/src/index.css"],
      "@flowform/styles/*": ["../styles/src/*"],
      "react": ["../../my-react-app/node_modules/@types/react"],
      "react-dom": ["../../my-react-app/node_modules/@types/react-dom"],
      "react/jsx-runtime": ["../../my-react-app/node_modules/@types/react/jsx-runtime.d.ts"],
      "react-router-dom": ["../../my-react-app/node_modules/react-router-dom"],
      "@flowform/ui": ["../ui/src/index.tsx"],
      "@flowform/ui/styles": ["../ui/src/styles/index.css"],
      "@flowform/ui/styles/*": ["../ui/src/styles/*"]
    },
    "types": ["react", "react-dom"],
    "typeRoots": ["../../my-react-app/node_modules/@types"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true
  },
  "include": ["src"]
}
