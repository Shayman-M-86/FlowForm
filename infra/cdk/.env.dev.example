# Real values for the two Secrets Manager entries security_stack.py creates,
# for the dev environment (flowform/dev/app-secrets, flowform/dev/db-secrets).
#
# Copy to .env.dev (gitignored) and fill in — never commit real values.
# For staging/prod, copy to .env.staging / .env.prod instead.
#
# Used by scripts/seed-secrets.sh --env dev to push these into AWS after
# `cdk deploy`.

# flowform/dev/app-secrets
APP_SECRET_KEY=
AUTH0_MGMT_SECRET=
LINKAGE_SECRET=

# flowform/dev/db-secrets
DB_CORE_APP_PASSWORD=
DB_RESPONSE_APP_PASSWORD=
