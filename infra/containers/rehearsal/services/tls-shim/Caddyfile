# Rehearsal TLS shim — runs on the ls-vm (230), beside LocalStack and the
# private registry.
#
# Makes the fake-AWS endpoints AND the fake-ECR registry present TLS on :443
# under SNI names, so the app box reaches them exactly the way it reaches real
# AWS/ECR: CONNECT <host>:443 → Squid (SNI allow-list) → TLS tunnel → here →
# terminate TLS → LocalStack :4566 (services) or the registry :5000.
#
# The ONLY deltas from prod are the hostnames (*.localstack.test) and a
# rehearsal-only CA (ca/rehearsal-ca.crt, a throwaway committed for the local
# rehearsal). Never mistake this for real AWS proof.
#
# Uses a PRE-GENERATED cert (ca/localstack.crt signed by ca/rehearsal-ca.crt) so
# the app box can trust the CA root baked at build time — no fetch-from-shim
# chicken-and-egg. The app box only needs ca/rehearsal-ca.crt in its trust store.

{
	admin off
	auto_https disable_redirects
}

secretsmanager.localstack.test, ssm.localstack.test, kms.localstack.test {
	tls /etc/caddy/certs/localstack.crt /etc/caddy/certs/localstack.key
	# LocalStack is bound to loopback; the shim is network_mode: host so lo works.
	reverse_proxy http://127.0.0.1:4566
}

# Fake-ECR: the private registry fronted with TLS so image pulls/pushes ride
# CONNECT registry.localstack.test:443 → Squid → here → registry, mirroring
# prod's ECR-over-HTTPS instead of a plain-HTTP insecure registry. Same leaf
# (registry.localstack.test is a SAN in ca/san.cnf). Registry publishes on
# loopback (127.0.0.1:5000) — the shim is network_mode: host, so lo reaches it.
registry.localstack.test {
	tls /etc/caddy/certs/localstack.crt /etc/caddy/certs/localstack.key
	reverse_proxy http://127.0.0.1:5000
}
