# FlowForm API reverse proxy (legacy single-host file).
#
# The split EC2 deployment uses caddy/Caddyfile.proxy via
# docker-compose.proxy.yml. Keep this file only for older manual experiments.
#
# Parameterised via environment:
#   API_DOMAIN  - the public API hostname, e.g. api.flow-form.com.au
#
# Local runs override TLS by supplying a different Caddyfile that uses
# `tls internal` instead of the Route 53 issuer (see docker-compose.ec2.local.yml).

{$API_DOMAIN} {
	tls {
		dns route53
	}

	reverse_proxy backend:5000

	log {
		output stdout
		format console
	}
}
