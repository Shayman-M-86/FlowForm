# Copy this file to proxmox-source.env in the same directory and update the
# values for your Proxmox host. The local file is ignored by Git.

# SSH connection used by `image prepare proxmox`. Authentication remains in
# your SSH agent/config; do not put passwords or private keys in this file.
PROXMOX_SSH_IDENTITY_FILE=/home/someuser/.ssh/id_rsa
PROXMOX_SSH_TARGET=root@pve.example.lan
PROXMOX_SSH_PORT=22

# Proxmox resources used to create the reusable Packer source template.
PROXMOX_NODE=pve
PROXMOX_SOURCE_VMID=8999
PROXMOX_SOURCE_TEMPLATE_NAME=amazon-linux-2023-kvm-base
PROXMOX_STORAGE_POOL=ZFS-RAIDZ
PROXMOX_SNIPPET_STORAGE=local
PROXMOX_SNIPPET_DIR=/var/lib/vz/snippets
PROXMOX_NETWORK_BRIDGE=vmbr0
PROXMOX_CPU_TYPE=x86-64-v2-AES
# Preserve the official image's native 25 GiB disk. Set an explicit larger IEC
# size only when required, and raise PROXMOX_DISK_MAX_SIZE deliberately with it.
PROXMOX_SOURCE_DISK_SIZE=native
PROXMOX_DISK_MAX_SIZE=25G
PROXMOX_SOURCE_MEMORY=2048
PROXMOX_SOURCE_CORES=2
PROXMOX_BUILD_TIMEOUT_SECONDS=1800
PROXMOX_IMAGE_CACHE_DIR=/var/lib/vz/template/iso

# Pinned official Amazon Linux 2023 KVM source. Update the release, filename,
# URL, and checksum together after verifying them against the official index.
AL2023_RELEASE=2023.12.20260710.0
AL2023_IMAGE_FILENAME=al2023-kvm-2023.12.20260710.0-kernel-6.1-x86_64.xfs.gpt.qcow2
AL2023_IMAGE_URL=https://cdn.amazonlinux.com/al2023/os-images/2023.12.20260710.0/kvm/al2023-kvm-2023.12.20260710.0-kernel-6.1-x86_64.xfs.gpt.qcow2
AL2023_IMAGE_SHA256=092002e43e67dcb2c2380778b64b0197ad3594935bd61709eae9557e3655c007
