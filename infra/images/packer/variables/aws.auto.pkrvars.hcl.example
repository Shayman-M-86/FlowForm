# Copy to aws.auto.pkrvars.hcl and fill with AWS values. Do not commit the copy.
aws_region               = "ap-southeast-2"
aws_source_ami_owner     = "amazon"
aws_source_ami_name      = "al2023-ami-minimal-2023.*-kernel-6.1-x86_64"
aws_instance_type        = "t3.small"
aws_subnet_id            = "subnet-REPLACE_ME"
aws_security_group_id    = "sg-REPLACE_ME"
aws_iam_instance_profile = "FlowFormPackerBuildProfile"
aws_ami_name_prefix      = "flowform-rehearsal-golden-al2023"
aws_root_volume_size     = 10
aws_encrypt_boot         = true
aws_kms_key_id           = ""
aws_architecture         = "x86_64"
ssh_username             = "ec2-user"
source_commit            = "git-sha-here"
