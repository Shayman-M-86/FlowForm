# Copy to proxmox.auto.pkrvars.hcl and fill with your Proxmox values. Do not commit the copy.
# proxmox_source_template should be a minimal template imported from the official
# Amazon Linux 2023 KVM qcow2 image and bootable with cloud-init/SSH for ec2-user.
proxmox_api_url         = "https://pve.example.lan:8006/api2/json"
proxmox_node            = "pve"
proxmox_token_id        = "packer@pve!flowform"
proxmox_token_secret    = "REPLACE_ME"
proxmox_storage_pool    = "ZFS-RAIDZ"
proxmox_source_template = "amazon-linux-2023-kvm-base"
proxmox_network_bridge  = "vmbr0"
proxmox_vm_id           = 9000
proxmox_template_name   = "flowform-rehearsal-golden-al2023"
proxmox_cpu             = 2
proxmox_memory          = 2048
ssh_username            = "ec2-user"
source_commit           = "git-sha-here"
