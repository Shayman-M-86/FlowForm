# Per-environment values, one file per env: copy to .env.dev / .env.staging /
# .env.prod (all gitignored) and fill in — never commit real values.
#
# Two consumers:
#   1. get_env_config() (synth time) — reads the AUTH0_* public config below
#      to build the Amplify studio-app env vars (full-deployment envs only;
#      dev has no Amplify app and can omit them).
#   2. infra/platforms/aws/scripts/seed-secrets.sh --env <env> — pushes the secret values into
#      Secrets Manager after `cdk deploy`.

# Public Auth0 config for the studio-app SPA (synth time; not secret —
# these ship in the built JS bundle).
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=

# flowform/dev/app-secrets
APP_SECRET_KEY=
AUTH0_MGMT_SECRET=
LINKAGE_SECRET=

# flowform/dev/db-secrets
DB_CORE_APP_PASSWORD=
DB_RESPONSE_APP_PASSWORD=
